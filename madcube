		-- Face player + chaotic micro-jitter
		hunter.CFrame = CFrame.lookAt(hunter.Position, targetPos) * CFrame.Angles(
			math.rad(math.random(-3,3)), math.rad(math.random(-3,3)), 0
		)
		
