-- == CHAOTIC ROBLOX LOCALSCRIPT - TIME-BASED MULTI-PHASE SURVIVAL HUNTER ==
-- Paste this as a LocalScript in StarterPlayer > StarterPlayerScripts
-- 100% LOCALPLAYER ONLY. No effects or damage on any other players.
-- Instantly ends + all sounds stop the moment YOU die.
-- Constant chase + face. Super chaotic with tons of particles, debris, knockback, and overlapping attacks.

local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local SoundService = game:GetService("SoundService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- INSTANT DEATH CLEANUP
local alive = true
humanoid.Died:Connect(function()
	alive = false
end)

-- ==================== CREATE THE HUNTER ====================
local hunter = Instance.new("Part")
hunter.Name = "ChaosHunter"
hunter.Size = Vector3.new(18, 22, 18) -- large non-sphere block
hunter.Shape = Enum.PartType.Block
hunter.Material = Enum.Material.Plastic
hunter.Color = Color3.fromRGB(255, 255, 255)
hunter.Transparency = 0
hunter.Anchored = true
hunter.CanCollide = true
hunter.Parent = workspace

-- Starting face decal
local faceDecal = Instance.new("Decal")
faceDecal.Face = Enum.NormalId.Front
faceDecal.Texture = "rbxassetid://107769019594430"
faceDecal.Parent = hunter

-- Random spawn ~80 studs away
local randomDir = Vector3.new(math.random(-1,1), 0, math.random(-1,1)).Unit * 80
hunter.Position = humanoidRootPart.Position + randomDir + Vector3.new(0, 10, 0)

-- ==================== CONSTANT DAMAGE + KNOCKBACK ON TOUCH ====================
hunter.Touched:Connect(function(hit)
	if not alive then return end
	if hit and hit:IsDescendantOf(character) then
		humanoid:TakeDamage(15)
		
		-- Knockback with 0.1s BodyVelocity
		local bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(4000, 4000, 4000)
		local knockDir = (hit.Position - hunter.Position).Unit * 85 + Vector3.new(0, 30, 0)
		bv.Velocity = knockDir
		bv.Parent = humanoidRootPart
		task.delay(0.1, function() bv:Destroy() end)
	end
end)

-- ==================== SOUND HELPER ====================
local activeSounds = {}
local function playSound(id, volume, playbackSpeed, parent, loop)
	volume = volume or 1
	playbackSpeed = playbackSpeed or 1
	parent = parent or hunter
	
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://" .. id
	sound.Volume = volume
	sound.PlaybackSpeed = playbackSpeed
	sound.Looped = loop or false
	sound.Parent = parent
	sound:Play()
	table.insert(activeSounds, sound)
	
	sound.Ended:Connect(function()
		if table.find(activeSounds, sound) then
			table.remove(activeSounds, table.find(activeSounds, sound))
		end
		sound:Destroy()
	end)
	
	return sound
end

-- Cleanup all sounds on death
local function stopAllSounds()
	for _, s in ipairs(activeSounds) do
		if s then s:Stop() s:Destroy() end
	end
	activeSounds = {}
end

-- ==================== SCREEN SHAKE ====================
local function screenShake(duration, intensity)
	if not alive then return end
	local conn
	local start = tick()
	conn = RunService.RenderStepped:Connect(function()
		if not alive or tick() - start > duration then
			conn:Disconnect()
			return
		end
		local offset = Vector3.new(math.random(-intensity,intensity)/6, math.random(-intensity,intensity)/6, 0)
		workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame * CFrame.new(offset)
	end)
end

-- ==================== SLASH ATTACK (visual + hitbox) ====================
local function createSlashAttack()
	if not alive then return end
	
	-- Visual thin long neon part (flashes + random rotation tween)
	local visual = Instance.new("Part")
	visual.Size = Vector3.new(0.1, 0.1, 1000)
	visual.Material = Enum.Material.Neon
	visual.Color = Color3.fromRGB(255, 255, 0)
	visual.Transparency = 0.2
	visual.Anchored = true
	visual.CanCollide = false
	visual.CFrame = hunter.CFrame * CFrame.new(0, 0, -5) * CFrame.Angles(math.rad(math.random(-90,90)), math.rad(math.random(-90,90)), math.rad(math.random(-90,90)))
	visual.Parent = workspace
	
	-- Rapid flash + smooth random rotation tween (0.1s)
	task.spawn(function()
		for i = 1, 8 do
			if not alive then visual:Destroy() return end
			visual.Color = (i % 2 == 0) and Color3.fromRGB(255, 255, 0) or Color3.fromRGB(255, 0, 0)
			local randomRot = CFrame.Angles(math.rad(math.random(-180,180)), math.rad(math.random(-180,180)), math.rad(math.random(-180,180)))
			TweenService:Create(visual, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = visual.CFrame * randomRot}):Play()
			task.wait(0.025)
		end
	end)
	
	-- After visual starts, spawn the ACTUAL hitbox slash
	task.delay(0.1, function()
		if not alive then return end
		local hitbox = Instance.new("Part")
		hitbox.Size = Vector3.new(3, 3, 1000)
		hitbox.Material = Enum.Material.Neon
		hitbox.Color = Color3.fromRGB(255, 0, 0)
		hitbox.Transparency = 0.3
		hitbox.Anchored = true
		hitbox.CanCollide = false
		hitbox.CFrame = visual.CFrame
		hitbox.Parent = workspace
		
		-- Damage on touch (only localplayer)
		hitbox.Touched:Connect(function(hitPart)
			if not alive then return end
			if hitPart and hitPart:IsDescendantOf(character) then
				humanoid:TakeDamage(7)
			end
		end)
		
		-- Tween shrink to 0,0,1000 then delete
		local shrinkTween = TweenService:Create(hitbox, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = Vector3.new(0, 0, 1000)
		})
		shrinkTween:Play()
		shrinkTween.Completed:Connect(function()
			hitbox:Destroy()
		end)
		
		-- Visual fades out
		task.delay(0.4, function() if visual then visual:Destroy() end end)
	end)
	
	playSound(136999902658730, 5, 1, workspace)
end

-- ==================== MAIN TIME-BASED CHAOS LOOP ====================
task.spawn(function()
