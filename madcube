					Position = rock.Position + Vector3.new(0, 10, 0)
				}):Play()
				
				task.delay(0.7, function()
					if not alive or not rock then return end
					rock.Anchored = false
					rock.Velocity = (humanoidRootPart.Position - rock.Position).Unit * 110 + Vector3.new(0, 40, 0)
					
					-- Explode on impact with rock debris
					rock.Touched:Connect(function(hit)
						if not alive then return end
						if hit:IsDescendantOf(character) then
							humanoid:TakeDamage(19)
