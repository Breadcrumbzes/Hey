			break
			
		elseif elapsed >= 150 and currentPhase < 4 then
			currentPhase = 4
			frozen = true
			faceDecal.Texture = "rbxassetid://120341831299080"
			
			-- Freeze player character
			humanoid.PlatformStand = true
			humanoid.WalkSpeed = 0
			humanoid.JumpPower = 0
			
			-- Play special audio from hunter
			playSound(140736374485942, 10, 1, hunter, false)
			
			-- Camera cinematic tween (10 studs in front → 5 studs in front, facing hunter)
			workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
			local camStartPos = hunter.Position + hunter.CFrame.LookVector * 10
			local camGoalPos = hunter.Position + hunter.CFrame.LookVector * 5
			
			TweenService:Create(workspace.CurrentCamera, TweenInfo.new(5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
				CFrame = CFrame.lookAt(camStartPos, hunter.Position)
			}):Play()
			
			task.delay(5, function()
				if not alive then return end
				TweenService:Create(workspace.CurrentCamera, TweenInfo.new(5, Enum.EasingStyle.Sine), {
					CFrame = CFrame.lookAt(camGoalPos, hunter.Position)
				}):Play()
			end)
			
			-- At +7 seconds into this phase: face switch + rapid shake + looped sound + song change
			task.delay(7, function()
				if not alive then return end
				faceDecal.Texture = "rbxassetid://91469937282906"
				playSound(111783701501789, 6, 1, hunter, true) -- looped
				if musicSound then musicSound:Destroy() end
				musicSound = playSound(139942137831770, 4, 1, SoundService, true)
				
				-- Chase speed *2x (even though frozen, for later logic)
				currentSpeed = currentSpeed * 2
				
				-- Rapid shake while frozen
				task.spawn(function()
					while alive and frozen do
						hunter.Orientation = hunter.Orientation + Vector3.new(math.random(-35,35), math.random(-25,25), math.random(-20,20))
						task.wait(0.008)
