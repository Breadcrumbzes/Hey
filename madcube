				rock.Material = Enum.Material.Rock
				rock.Color = Color3.fromRGB(math.random(80,140), math.random(80,140), math.random(80,140))
				rock.Position = hunter.Position + Vector3.new(math.random(-25,25), math.random(-10,35), math.random(-25,25))
				rock.CanCollide = true
				rock.Anchored = false
				rock.Velocity = Vector3.new(math.random(-280,280), math.random(120,380), math.random(-280,280))
