								orb.Color = Color3.fromRGB(255,255,255)
								TweenService:Create(orb, TweenInfo.new(1.2, Enum.EasingStyle.Quad), {Transparency = 1, Size = Vector3.new(0.1,0.1,0.1)}):Play()
