		elseif elapsed >= 80 and currentPhase < 3 then
			currentPhase = 3
			faceDecal.Texture = "rbxassetid://112475315234322"
			currentSpeed = currentSpeed * 1.5
			
			if musicSound then musicSound:Destroy() end
			musicSound = playSound(138572180557517, 3.5, 1, SoundService, true)
			
			-- Faster slashes + slash circle every 5s
			-- Red neon orb rain
			rainTask = task.spawn(function()
				while alive and currentPhase == 3 do
					-- Red neon orbs rain down
					for i = 1, 6 do
						local orb = Instance.new("Part")
						orb.Size = Vector3.new(5,5,5)
						orb.Material = Enum.Material.Neon
						orb.Color = Color3.fromRGB(255, 50, 0)
						orb.Position = humanoidRootPart.Position + Vector3.new(math.random(-45,45), 110, math.random(-45,45))
						orb.Velocity = Vector3.new(math.random(-30,30), -120, math.random(-30,30))
						orb.CanCollide = false
						orb.Parent = workspace
						
						local blast = nil
