		-- ==================== PHASE TRANSITIONS ====================
		if elapsed >= 180 and currentPhase < 5 then
			currentPhase = 5
			frozen = true
			-- Final explosion phase
			screenShake(3, 25)
			playSound(111783701501789, 8, 1.2, hunter) -- already looping but speed up
			
			-- Speed up the looped shake sound
			task.spawn(function()
				local shakeSpeed = 1.2
				while alive and (tick() - startTime) < 185 do
					shakeSpeed = shakeSpeed + 0.4
					if musicSound then musicSound.PlaybackSpeed = shakeSpeed end
					hunter.Orientation = hunter.Orientation + Vector3.new(math.sin(tick()*80)*40, math.sin(tick()*60)*30, 0)
					task.wait(0.02)
				end
			end)
			
			-- Explode into 50 large unanchored stone rocks
			for i = 1, 50 do
				local rock = Instance.new("Part")
				rock.Size = Vector3.new(math.random(6,14), math.random(6,14), math.random(6,14))
