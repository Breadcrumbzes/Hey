			musicSound = playSound(140725984089213, 4, 1, SoundService, true)
			
			-- Slash rate becomes 3x faster (every ~1.67s)
		end
		
		-- ==================== ATTACK SCHEDULERS ====================
		-- Normal slashes (rate increases per phase)
		local slashRate = (currentPhase == 1) and 5 or (currentPhase == 2) and 1.67 or (currentPhase >= 3) and 0.9
		if elapsed - lastSlashTime >= slashRate then
			lastSlashTime = elapsed
			createSlashAttack()
			
			-- Extra scatter in later phases
			if currentPhase >= 3 and math.random() < 0.7 then
				task.delay(0.1, createSlashAttack)
			end
		end
		
		-- Slash circles (phase 3+ every 5s, more violent in phase 4)
		if currentPhase >= 3 and elapsed - lastSlashCircleTime >= 5 then
			lastSlashCircleTime = elapsed
			for i = 1, (currentPhase == 4 and 24 or 14) do
				task.delay(i * 0.03, function()
					if not alive then return end
					local angle = i * (360 / (currentPhase == 4 and 24 or 14))
					local offset = CFrame.Angles(0, math.rad(angle), 0)
					local slashPos = humanoidRootPart.Position + offset.LookVector * 18 + Vector3.new(0, 8, 0)
					
