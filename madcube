							-- Bigger debris storm
							for d = 1, 14 do
								local debris = Instance.new("Part")
								debris.Size = Vector3.new(math.random(2,5), math.random(2,5), math.random(2,5))
								debris.Material = groundMat
								debris.Color = groundColor
								debris.Position = rock.Position
								debris.Velocity = Vector3.new(math.random(-140,140), math.random(80,160), math.random(-140,140))
								debris.CanCollide = false
								debris.Parent = workspace
								debris.Touched:Connect(function(h) if alive and h:IsDescendantOf(character) then humanoid:TakeDamage(8) end end)
								task.delay(3.5, function() if debris then debris:Destroy() end end)
							end
						end
					end)
				end)
			end
		end
		
		task.wait(0.01)
	end
	
	-- FINAL CLEANUP
	chaseConnection:Disconnect()
	if rainTask then task.cancel(rainTask) end
	for _, orb in ipairs(orbitingOrbs) do if orb then orb:Destroy() end end
	if hunter then hunter:Destroy() end
	stopAllSounds()
	workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
	
	print("✅ TIME-BASED CHAOS HUNTER LOCALSCRIPT LOADED - ONLY AFFECTS YOU - ULTRA CHAOTIC")
end)
