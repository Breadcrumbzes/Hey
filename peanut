local function AnimateBeam(beam, duration, initialWidth)
	initialWidth = initialWidth or 0.3
	local steps = math.max(1, math.floor(10 * duration))
	for i = 1, steps do
		local currentWidth = initialWidth - (initialWidth / steps) * i
		beam.Width0 = currentWidth
		beam.Width1 = currentWidth
		local fade = 0.5 + (0.5 / steps) * i
		beam.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, fade),
			NumberSequenceKeypoint.new(1, fade),
		})
		task.wait(0.03 * duration)
	end
	beam.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(1, 1),
	})
end

local function playBeam(startPos, endPos, beamName, lifetime, color, widthScale)
	lifetime = lifetime or 1
	widthScale = widthScale or 1
	local startAttachment = Instance.new("Attachment")
	startAttachment.WorldPosition = startPos
	startAttachment.Parent = workspace.Terrain
	local endAttachment = Instance.new("Attachment")
	endAttachment.WorldPosition = endPos
	endAttachment.Parent = workspace.Terrain
	local beamTemplate = BeamFolder:FindFirstChild(beamName)
	if not beamTemplate then
		warn("Beam template not found: " .. tostring(beamName))
		return
	end
	local beam = beamTemplate:Clone()
	beam.Parent = startAttachment
	beam.Attachment0 = startAttachment
	beam.Attachment1 = endAttachment
	if color then
		beam.Color = ColorSequence.new(color, color)
	end
	if widthScale and widthScale ~= 1 then
		beam.Width0 = math.min(beam.Width0 * widthScale, 12)
		beam.Width1 = math.min(beam.Width1 * widthScale, 12)
	end
	TweenService:Create(beam, TweenInfo.new(lifetime * 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Width0 = 0,
		Width1 = 0,
	}):Play()
	Debris:AddItem(startAttachment, lifetime)
	Debris:AddItem(endAttachment, lifetime)
	task.spawn(function()
		AnimateBeam(beam, lifetime, beam.Width0)
	end)
end

local function hitbox(size, cframe, part)
	local main = part or torso
	local cf = main.CFrame * cframe
	local params = OverlapParams.new()
	params.FilterDescendantsInstances = {character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	local parts = workspace:GetPartBoundsInBox(cf, size, params)
	local hitCharacters, hits = {}, {}
	for _, part in ipairs(parts) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model then
			local hum = model:FindFirstChildOfClass("Humanoid")
			if hum and not hitCharacters[model] then
				hitCharacters[model] = true
				table.insert(hits, part)
			end
		end
	end
	return hits
end

