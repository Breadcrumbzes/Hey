function ApplyGravity(model, gravityScale)
	local bodyForce = model.PrimaryPart:FindFirstChild("BodyForce")

	if not bodyForce then
		bodyForce = Instance.new("BodyForce")
	end

	local totalMass = 0
	for _, part in pairs(model:GetDescendants()) do
		if part:IsA("BasePart") then
			totalMass += part:GetMass()
		end
	end

	bodyForce.Force = Vector3.new(0, totalMass * 196.2 * (1 - gravityScale), 0)
	bodyForce.Parent = model.HumanoidRootPart
end

local function VisibleModel(object, isVisible)
	if object:IsA("BasePart") then
