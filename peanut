local function playEffect(typer, position, color)
	local visual = ServerStorage:FindFirstChild("CesusVisuals"):FindFirstChild(typer)
	if not visual then return end

	local particletime = visual:GetAttribute("ParticleTime") or 1
	local part = Instance.new("Part")
	part.Anchored = true
	part.Transparency = 1
	part.CanCollide = false
	part.Size = Vector3.new(0.01, 0.01, 0.01)
	part.Position = position
	part.Parent = workspace
	Debris:AddItem(part, 30)

	local effects = {}
	for _, v in pairs(visual:GetChildren()) do
		local clone = v:Clone()
		clone.Parent = part
		table.insert(effects, clone)
	end

	for _, v in pairs(effects) do
		if v:IsA("Sound") then
			v:Play()
		elseif v:IsA("ParticleEmitter") or v:IsA("PointLight") then
			v.Enabled = true

			if color then
				local canColor = v:GetAttribute("CanColor")
				if canColor == true then
					if v:IsA("ParticleEmitter") then
						v.Color = ColorSequence.new(color)
					elseif v:IsA("PointLight") then
						v.Color = color
					end
				end
			end

		elseif v:IsA("Script") then
			v.Enabled = true
		end
	end

	task.delay(particletime, function()
		for _, v in pairs(effects) do
			if v:IsA("ParticleEmitter") or v:IsA("PointLight") then
				v.Enabled = false
			end
		end
	end)
end

