local function createShutdownFlash(isWin: boolean)
	local flashColor = if isWin then Color3.fromRGB(0, 255, 80) else Color3.fromRGB(255, 0, 0)

	if greenGui then
		greenGui:Destroy()
	end

	greenGui = Instance.new("ScreenGui")
	greenGui.Name = "ShutdownFlashGui"
	greenGui.IgnoreGuiInset = true
	greenGui.ResetOnSpawn = false
	greenGui.DisplayOrder = 999999
	greenGui.Parent = PlayerGui

	greenFrame = Instance.new("Frame")
	greenFrame.Size = UDim2.fromScale(1, 1)
	greenFrame.BackgroundColor3 = flashColor
	greenFrame.BackgroundTransparency = 1
	greenFrame.BorderSizePixel = 0
	greenFrame.Parent = greenGui

	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 0
	stroke.Transparency = 1
	stroke.Parent = greenFrame

	TweenService:Create(greenFrame, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.2,
	}):Play()

	task.delay(0.12, function()
		if greenFrame and greenFrame.Parent then
			TweenService:Create(greenFrame, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				BackgroundTransparency = 1,
			}):Play()
		end
	end)
end

local function stopAllMusic()
	for _, sound in pairs(phaseSounds) do
		pcall(function()
			sound.Volume = 0
			sound:Stop()
		end)
	end
end

local function cleanupAll()
	if cleanupDone then
		return
	end
	cleanupDone = true

	for _, conn in ipairs(connections) do
		pcall(function()
			conn:Disconnect()
		end)
	end
	table.clear(connections)

	for _, conn in ipairs(apocalypseOrbConnections) do
		pcall(function()
			conn:Disconnect()
		end)
	end
	table.clear(apocalypseOrbConnections)

	stopAllMusic()

	if greenGui then
		greenGui:Destroy()
		greenGui = nil
		greenFrame = nil
	end

	if chaosFolder and chaosFolder.Parent then
		chaosFolder:Destroy()
	end

	if musicFolder and musicFolder.Parent then
		musicFolder:Destroy()
	end
end

local function beginShutdown(isWin: boolean)
	if shuttingDown then
		return
	end
	shuttingDown = true
	running = false

	stopAllMusic()
	createShutdownFlash(isWin)

	task.delay(0.55, function()
		cleanupAll()
	end)
end

