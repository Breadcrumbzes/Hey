--!strict
-- 120-second chaos LocalScript with phase music + shutdown flash
-- Put this in StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local Lighting = game:GetService("Lighting")
local SoundService = game:GetService("SoundService")
local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local DURATION = 120
local START_TIME = os.clock()

local SND = {
	Explosion = "rbxassetid://140615626179933",
	Shriek = "rbxassetid://135049904093550",
	Horn = "rbxassetid://121533907629378",
	Worm = "rbxassetid://111993673815478",
	Missile = "rbxassetid://113032480637316",
}

local MUSIC = {
	Calm = "rbxassetid://139770038067721",
	Warmup = "rbxassetid://140736185536900",
	Escalation = "rbxassetid://140730997974832",
	Apocalypse = "rbxassetid://140646145129329",
}

local running = true
local shuttingDown = false
local cleanupDone = false
local activePhase = ""
local connections: { RBXScriptConnection } = {}

local apocalypseOrbsBuilt = false
local apocalypseOrbConnections: { RBXScriptConnection } = {}

local function track(conn: RBXScriptConnection)
	table.insert(connections, conn)
	return conn
end

local function alive(): boolean
	return running and (os.clock() - START_TIME < DURATION)
end

local function progress(): number
	return math.clamp((os.clock() - START_TIME) / DURATION, 0, 1)
end

local function ramp(): number
	local p = progress()
	return p * p
end

local function currentPhase(): string
	local p = progress()
	if p < 0.20 then
		return "Calm"
	elseif p < 0.45 then
		return "Warmup"
	elseif p < 0.75 then
		return "Escalation"
	else
		return "Apocalypse"
	end
end

local function getCharacter()
	local char = player.Character or player.CharacterAdded:Wait()
	local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart")
	return char, hum, hrp
end

local character, humanoid, hrp = getCharacter()

local chaosFolder = Instance.new("Folder")
chaosFolder.Name = "RampingChaosLocal"
chaosFolder.Parent = workspace

local musicFolder = Instance.new("Folder")
musicFolder.Name = "PhaseMusicLocal"
musicFolder.Parent = SoundService

local phaseSounds: { [string]: Sound } = {}

local function makePhaseSound(name: string, id: string)
	local s = Instance.new("Sound")
	s.Name = name .. "Music"
	s.SoundId = id
	s.Volume = 0
	s.Looped = true
	s.Parent = musicFolder
	phaseSounds[name] = s
	return s
end

makePhaseSound("Calm", MUSIC.Calm)
makePhaseSound("Warmup", MUSIC.Warmup)
makePhaseSound("Escalation", MUSIC.Escalation)
makePhaseSound("Apocalypse", MUSIC.Apocalypse)

local function playPhaseMusic(name: string)
	if activePhase == name or shuttingDown then
		return
	end

	activePhase = name
	local targetVolumes = {
		Calm = 0.65,
		Warmup = 0.72,
		Escalation = 0.8,
		Apocalypse = 0.9,
	}

	for phaseName, sound in pairs(phaseSounds) do
		if phaseName == name then
			if not sound.IsPlaying then
				sound:Play()
			end
			TweenService:Create(sound, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Volume = targetVolumes[phaseName] or 0.7,
			}):Play()
		else
			if sound.IsPlaying then
				local tw = TweenService:Create(sound, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Volume = 0,
				})
				tw:Play()
				task.delay(0.55, function()
					pcall(function()
						sound:Stop()
					end)
				end)
			end
		end
	end
end

local function mkSound(id: string, parent: Instance, volume: number, speed: number?, looped: boolean?)
	local s = Instance.new("Sound")
	s.SoundId = id
	s.Volume = volume
	s.PlaybackSpeed = speed or 1
	s.Looped = looped or false
	s.Parent = parent
	s:Play()
	return s
end

local function mkPart(
	size: Vector3,
	cf: CFrame,
	color: Color3,
	material: Enum.Material,
	anchored: boolean,
	canCollide: boolean,
	transparency: number?
)
	local p = Instance.new("Part")
	p.Size = size
	p.CFrame = cf
	p.Color = color
	p.Material = material
	p.Anchored = anchored
	p.CanCollide = canCollide
	p.CanTouch = false
	p.CanQuery = false
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Transparency = transparency or 0
	p.Parent = chaosFolder
	return p
end

local function applyLocalDamage(amount: number)
	if humanoid and humanoid.Parent then
		humanoid:TakeDamage(amount)
	end
end

local function applyKnockback(direction: Vector3, force: number)
	if hrp and hrp.Parent and direction.Magnitude > 0.001 then
		local bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
		bv.P = 12500
		bv.Velocity = direction.Unit * force + Vector3.new(0, math.random(6, 24), 0)
		bv.Parent = hrp
		Debris:AddItem(bv, 0.16)
	end
end

local function explosionFlash(pos: Vector3, radius: number, pressure: number)
	local boom = Instance.new("Explosion")
	boom.Position = pos
	boom.BlastRadius = radius
	boom.BlastPressure = pressure
	boom.DestroyJointRadiusPercent = 0
	boom.Parent = workspace

	local flash = mkPart(Vector3.new(1, 1, 1), CFrame.new(pos), Color3.new(1, 0.75, 0.2), Enum.Material.Neon, true, false, 0.2)
	flash.Shape = Enum.PartType.Ball

	TweenService:Create(flash, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(radius * 6, radius * 6, radius * 6),
	}):Play()

	mkSound(SND.Explosion, flash, 1.8, 0.9 + math.random() * 0.25, false)
	Debris:AddItem(flash, 0.5)
	return boom
end

local function shockwave(pos: Vector3, startSize: number, endSize: number, color: Color3, life: number)
	local wave = mkPart(Vector3.new(startSize, startSize, startSize), CFrame.new(pos), color, Enum.Material.Neon, true, false, 0.45)
	wave.Shape = Enum.PartType.Ball
	TweenService:Create(wave, TweenInfo.new(life, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(endSize, endSize, endSize),
	}):Play()
	Debris:AddItem(wave, life + 0.05)
end

local function mushroomCloud(pos: Vector3)
	local stem = mkPart(Vector3.new(8, 18, 8), CFrame.new(pos), Color3.fromRGB(210, 180, 120), Enum.Material.SmoothPlastic, true, false, 0.1)
	stem.Shape = Enum.PartType.Cylinder
	stem.CFrame = CFrame.new(pos + Vector3.new(0, 8, 0)) * CFrame.Angles(0, 0, math.rad(90))

	local cap = mkPart(Vector3.new(18, 18, 18), CFrame.new(pos + Vector3.new(0, 18, 0)), Color3.fromRGB(255, 140, 40), Enum.Material.Neon, true, false, 0.2)
	cap.Shape = Enum.PartType.Ball

	local cap2 = mkPart(Vector3.new(28, 10, 28), CFrame.new(pos + Vector3.new(0, 24, 0)), Color3.fromRGB(120, 120, 120), Enum.Material.SmoothPlastic, true, false, 0.35)
	cap2.Shape = Enum.PartType.Ball

	TweenService:Create(stem, TweenInfo.new(2.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(12, 40, 12),
		CFrame = stem.CFrame + Vector3.new(0, 18, 0),
	}):Play()

	TweenService:Create(cap, TweenInfo.new(2.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(34, 34, 34),
		CFrame = cap.CFrame + Vector3.new(0, 18, 0),
	}):Play()

	TweenService:Create(cap2, TweenInfo.new(2.8, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(48, 20, 48),
		CFrame = cap2.CFrame + Vector3.new(0, 30, 0),
	}):Play()

	Debris:AddItem(stem, 3)
	Debris:AddItem(cap, 3)
	Debris:AddItem(cap2, 3)

	mkSound(SND.Explosion, stem, 1.2, 0.8, false)
	mkSound(SND.Horn, cap, 0.9, 1, false)
end

local function warningMarker(pos: Vector3, life: number)
	local marker = mkPart(Vector3.new(1, 1, 1), CFrame.new(pos), Color3.fromRGB(255, 60, 60), Enum.Material.Neon, true, false, 0.35)
	marker.Shape = Enum.PartType.Ball
	TweenService:Create(marker, TweenInfo.new(life, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(10, 10, 10),
	}):Play()
	Debris:AddItem(marker, life + 0.05)
	return marker
end

local function telegraphedMushroomExplosion(
	pos: Vector3,
	telegraphDelay: number?,
	telegraphTime: number?,
	damage: number?,
	knockForce: number?,
	blastRadius: number?,
	pressure: number?
)
	local startDelay = telegraphDelay or 0.1
	local warnTime = telegraphTime or 0.7

	local warn = mkPart(Vector3.new(2, 2, 2), CFrame.new(pos), Color3.fromRGB(255, 40, 40), Enum.Material.Neon, true, false, 0.15)
	warn.Shape = Enum.PartType.Ball

	local light = Instance.new("PointLight")
	light.Color = Color3.fromRGB(255, 230, 85)
	light.Range = 24
	light.Brightness = 3
	light.Parent = warn

	task.delay(startDelay, function()
		if not warn.Parent then
			return
		end

		local red = Color3.fromRGB(255, 50, 50)
		local yellow = Color3.fromRGB(255, 230, 80)
		local elapsed = 0
		local flashConn: RBXScriptConnection? = nil

		flashConn = RunService.Heartbeat:Connect(function(dt)
			if not warn.Parent then
				if flashConn then
					flashConn:Disconnect()
				end
				return
			end

			elapsed += dt
			local t = math.floor(elapsed * 12) % 2
			warn.Color = (t == 0) and red or yellow
			light.Color = (t == 0) and red or yellow
			light.Brightness = 2.6 + math.sin(elapsed * 16) * 0.6
		end)

		task.delay(warnTime, function()
			if flashConn then
				flashConn:Disconnect()
			end
			if warn.Parent then
				warn:Destroy()
			end

			explosionFlash(pos, blastRadius or 16, pressure or 600000)
			shockwave(pos, 8, 90, Color3.fromRGB(255, 180, 80), 0.8)
			mushroomCloud(pos)

			if damage and damage > 0 then
				applyLocalDamage(damage)
			end
			if knockForce and knockForce > 0 then
				local dir = hrp and hrp.Parent and (hrp.Position - pos) or Vector3.new(0, 1, 0)
				applyKnockback(dir, knockForce)
			end
		end)
	end)
end

local function createProjectile(origin: Vector3, target: Vector3, speed: number, radius: number, damage: number)
	local proj = mkPart(Vector3.new(radius, radius, radius), CFrame.new(origin), Color3.fromRGB(255, 70, 70), Enum.Material.Neon, true, false, 0)
	proj.Shape = Enum.PartType.Ball

	local a0 = Instance.new("Attachment")
	a0.Position = Vector3.new(0, radius * 0.5, 0)
	a0.Parent = proj

	local a1 = Instance.new("Attachment")
	a1.Position = Vector3.new(0, -radius * 0.5, 0)
	a1.Parent = proj

	local trail = Instance.new("Trail")
	trail.Attachment0 = a0
	trail.Attachment1 = a1
	trail.Lifetime = 0.3
	trail.MinLength = 0.1
	trail.Parent = proj

	mkSound(SND.Missile, proj, 1.2, 0.95 + math.random() * 0.2, false)

	local dir = target - origin
	if dir.Magnitude < 0.001 then
		dir = Vector3.new(0, 0, -1)
	end
	dir = dir.Unit

	local life = 0
	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not proj.Parent then
			if conn then
				conn:Disconnect()
			end
			if proj.Parent then
				proj:Destroy()
			end
			return
		end

		life += dt
		proj.CFrame = proj.CFrame + (dir * speed * dt)

		if hrp and hrp.Parent then
			local dist = (proj.Position - hrp.Position).Magnitude
			if dist < 4.5 then
				local hitPos = proj.Position
				explosionFlash(hitPos, 10 + radius * 4, 500000)
				shockwave(hitPos, 4, 18, Color3.new(1, 0.65, 0.2), 0.3)
				applyLocalDamage(damage)
				applyKnockback(hrp.Position - hitPos, 70 + radius * 18)

				if math.random() < 0.3 then
					if currentPhase() == "Apocalypse" then
						telegraphedMushroomExplosion(hitPos, 0.1, 0.7, 1, 55, 14, 220000)
					else
						mushroomCloud(hitPos)
					end
				end

				if conn then
					conn:Disconnect()
				end
				proj:Destroy()
				return
			end
		end

		if life > 10 then
			if conn then
				conn:Disconnect()
			end
			proj:Destroy()
		end
	end)
end

local function telegraphedMissile(origin: Vector3, target: Vector3, speed: number, radius: number, damage: number, delayTime: number)
	warningMarker(origin, delayTime)
	task.delay(delayTime, function()
		if not alive() then
			return
		end
		createProjectile(origin, target, speed, radius, damage)
	end)
end

local function createCubeDrone(spawnOffset: Vector3, size: number, speed: number, damage: number)
	local cube = mkPart(Vector3.new(size, size, size), hrp.CFrame * CFrame.new(spawnOffset), Color3.fromRGB(math.random(80, 255), math.random(20, 120), math.random(20, 120)), Enum.Material.Metal, true, false, 0)
	cube.Shape = Enum.PartType.Block
	mkSound(SND.Worm, cube, 0.6, 0.9 + math.random() * 0.25, true)

	local t = 0
	local spin = Vector3.new(math.random(-18, 18), math.random(-18, 18), math.random(-18, 18))
	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not cube.Parent or not hrp.Parent then
			if conn then
				conn:Disconnect()
			end
			if cube.Parent then
				cube:Destroy()
			end
			return
		end

		t += dt
		local orbitRadius = 70 + math.sin(t * 2.5) * 25
		local angle = t * (1.3 + math.random() * 0.6)
		local goal = hrp.Position + Vector3.new(math.cos(angle) * orbitRadius, math.sin(t * 4) * 8 + 6, math.sin(angle) * orbitRadius)
		local stepDir = goal - cube.Position

		if stepDir.Magnitude > 0.1 then
			cube.CFrame = CFrame.new(cube.Position + stepDir.Unit * speed * dt, hrp.Position)
				* CFrame.Angles(math.rad(spin.X * dt), math.rad(spin.Y * dt), math.rad(spin.Z * dt))
		end

		if (cube.Position - hrp.Position).Magnitude < 4.5 then
			local hitPos = cube.Position
			explosionFlash(hitPos, 7, 220000)
			shockwave(hitPos, 3, 16, Color3.new(1, 1, 1), 0.25)
			applyLocalDamage(damage)
			applyKnockback(hrp.Position - hitPos, 55)

			if math.random() < 0.5 then
				if currentPhase() == "Apocalypse" then
					telegraphedMushroomExplosion(hitPos, 0.1, 0.7, 1, 40, 12, 160000)
				else
					mushroomCloud(hitPos)
				end
			end

			if conn then
				conn:Disconnect()
			end
			cube:Destroy()
			return
		end

		if t > 12 then
			explosionFlash(cube.Position, 4, 90000)
			if conn then
				conn:Disconnect()
			end
			cube:Destroy()
		end
	end)
end

local function swarmOfCubes(count: number)
	for i = 1, count do
		local theta = (i / count) * math.pi * 2
		local offset = Vector3.new(
			math.cos(theta) * (80 + math.random(-10, 10)),
			math.random(-3, 14),
			math.sin(theta) * (80 + math.random(-10, 10))
		)
		createCubeDrone(offset, math.random(2, 5), 12 + math.random(0, 12), math.random(1, 6))
	end
end

local function missileRing(count: number)
	for i = 1, count do
		local theta = (i / count) * math.pi * 2
		local origin = hrp.Position + Vector3.new(math.cos(theta) * 110, 30 + math.random(-8, 12), math.sin(theta) * 110)
		local target = hrp.Position + Vector3.new(math.random(-4, 4), math.random(-2, 5), math.random(-4, 4))
		telegraphedMissile(origin, target, 70 + math.random(0, 50), math.random(2, 4), math.random(2, 7), 0.35 + math.random() * 0.35)
	end
end

local function missileStorm()
	for i = 1, math.random(8, 16) do
		task.delay(i * 0.08, function()
			if not alive() then
				return
			end
			local origin = hrp.Position + Vector3.new(math.random(-140, 140), math.random(30, 70), math.random(-140, 140))
