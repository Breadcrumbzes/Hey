task.spawn(function()
	while alive() and not creatureDead and lungeCount < 30 do
		if not alive() then
			break
		end

		lungeCount += 1
		lungeOnce(lungeCount)

		if not alive() or creatureDead then
			break
		end

		if lungeCount == 20 then
			updateCreatureAppearanceToRed()
		end

		if lungeCount < 30 then
			local gap = 0.18
			if lungeCount > 10 then
				gap = math.max(0.06, 0.18 - ((lungeCount - 10) * 0.01))
			end
			if lungeCount >= 20 then
				gap = math.max(0.03, gap * 0.55)
			end
			task.wait(gap)
		end
	end

	if alive() and not creatureDead then
		local shakeThreadStart = os.clock()
		while alive() and os.clock() - shakeThreadStart < 5 do
			cameraShake(1.6 + ((os.clock() - shakeThreadStart) * 0.8), 0.2)
			freezeAndPointUp()
			task.wait(0.03)
		end
		explodeCreatureFinal()
	end
end)

task.spawn(function()
	while alive() and not creatureDead do
		task.wait(0.02)

		if not alive() or creatureDead then
			break
		end

		-- Keep the creature facing the local player during its normal movement.
		if creature and creature.Parent and hrp and hrp.Parent then
			local targetPos = hrp.Position
			if lungeCount < 30 then
				creature.CFrame = CFrame.lookAt(creature.Position, targetPos)
			end
		end
	end
end)

