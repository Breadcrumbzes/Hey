local function updateCreatureAppearanceToRed()
	creature.Color = Color3.fromRGB(255, 0, 0)
	decal.Color3 = Color3.fromRGB(255, 40, 40)
	creatureLight.Color = Color3.fromRGB(255, 40, 40)
	creatureLight.Brightness = 6
	playSound(creature, "137944174609015", 3, 1, false)
	cameraShake(1.2, 1.2)
end

local function getLungeSpeedForIndex(index: number): number
	if index >= 20 then
		return 2.1 + ((index - 20) * 0.12)
	elseif index > 10 then
		return 1.35 + ((index - 10) * 0.08)
	else
		return 1
	end
end

local function lungeOnce(index: number)
	if creatureDead or not alive() then
		return
	end

	local target = hrp.Position
	local startPos = creature.Position
	local desiredStartSoundSpeed = 1

	if index > 10 then
		desiredStartSoundSpeed = 1 + ((index - 10) * 0.12)
	end
	if index >= 20 then
		desiredStartSoundSpeed = desiredStartSoundSpeed + 0.6
	end

	lungeStartSound.PlaybackSpeed = desiredStartSoundSpeed
	lungeStartSound:Stop()
	lungeStartSound:Play()

	cameraShake(0.22 + math.min(1.2, index * 0.03), 0.2)

	if index > 10 and index < 20 and (index % 3 == 0) then
		creature.CFrame = CFrame.lookAt(creature.Position, creature.Position + Vector3.yAxis)
		task.wait(0.15)
		doSpewBlackGoo()
		task.wait(0.4)
	elseif index >= 20 and (index % 3 == 0) then
		creature.CFrame = CFrame.lookAt(creature.Position, creature.Position + Vector3.yAxis)
		task.wait(0.12)
		doRedFreezeAndFire()
		task.wait(0.25)
	end

	local lungeSpeed = 70 * getLungeSpeedForIndex(index)
	local lungeDuration = math.clamp(0.85 / getLungeSpeedForIndex(index), 0.18, 0.85)
	local start = os.clock()

	lungeMoveSound.PlaybackSpeed = 1 + math.min(1.2, index * 0.02)
	lungeMoveSound:Stop()
	lungeMoveSound:Play()

	local trailTick = 0
	while alive() and not creatureDead and (os.clock() - start) < lungeDuration do
		local dt = RunService.Heartbeat:Wait()
		trailTick += dt

		if not alive() or creatureDead then
			break
		end

		if not hrp.Parent then
			break
		end

		local targetNow = hrp.Position
		local dir = (targetNow - creature.Position)
		if dir.Magnitude < 0.001 then
			dir = Vector3.new(0, 0, -1)
		end
		dir = dir.Unit

		creature.CFrame = CFrame.lookAt(creature.Position + (dir * lungeSpeed * dt), targetNow)

		if trailTick >= 0.03 then
			trailTick = 0
			doTrail()
		end

		if (creature.Position - hrp.Position).Magnitude <= 12.5 then
			damageLocalPlayer(2)
		end
	end

	if index == 10 then
		lungeStartSound:Stop()
		local s1 = playSound(creature, "95222170052486", 2.6, 1, false)
		s1.Ended:Wait()
		if alive() then
			local s2 = playSound(creature, "96184137289030", 2.2, 1, false)
			s2.Ended:Wait()
		end
		if alive() then
			local s3 = playSound(creature, "106068332784548", 2.2, 1, false)
			s3.Ended:Wait()
		end
		speedUpPhase = true
	elseif index == 20 then
		redPhase = true
		updateCreatureAppearanceToRed()
	end
end

local function freezeAndPointUp()
	creature.CFrame = CFrame.lookAt(creature.Position, creature.Position + Vector3.yAxis)
end

local function explodeCreatureFinal()
	if creatureDead then
		return
	end
	creatureDead = true

	local pos = creature.Position
	local burstSound = playSound(creature, "140615626179933", 3, 1, false)
	cameraShake(2.2, 0.9)

	local growTween = TweenService:Create(creature, TweenInfo.new(5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = creature.Size * 10,
		Transparency = 1,
	})
	growTween:Play()

	task.spawn(function()
		local t0 = os.clock()
		while alive() and os.clock() - t0 < 5 do
			freezeAndPointUp()
			creature.CFrame = creature.CFrame * CFrame.Angles(math.rad(24), math.rad(34), math.rad(18))
			task.wait(0.03)
		end
	end)

	spawnFinalGooAndOrbs(pos)

	for i = 1, 70 do
		task.delay(i * 0.02, function()
			if not alive() then
				return
			end
			local which = math.random(1, 3)
			if which == 1 then
				local p = mkPart(Vector3.new(1.4, 1.4, 1.4), CFrame.new(pos), Color3.fromRGB(0, 0, 0), Enum.Material.Neon, true, false, 0.1)
				p.Shape = Enum.PartType.Ball
				p.AssemblyLinearVelocity = Vector3.new(math.random(-120, 120), math.random(20, 130), math.random(-120, 120))
				TweenService:Create(p, TweenInfo.new(4.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Transparency = 1,
					Size = Vector3.new(0.2, 0.2, 0.2),
				}):Play()
				Debris:AddItem(p, 4.6)
			elseif which == 2 then
				local p = mkPart(Vector3.new(1.5, 1.5, 1.5), CFrame.new(pos), Color3.fromRGB(255, 0, 0), Enum.Material.Neon, true, false, 0.1)
				p.Shape = Enum.PartType.Ball
				p.AssemblyLinearVelocity = Vector3.new(math.random(-120, 120), math.random(30, 140), math.random(-120, 120))
				TweenService:Create(p, TweenInfo.new(4.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Transparency = 1,
					Size = Vector3.new(0.2, 0.2, 0.2),
				}):Play()
				Debris:AddItem(p, 4.6)
			else
				local p = mkPart(Vector3.new(1.6, 1.6, 1.6), CFrame.new(pos), Color3.fromRGB(255, 70, 0), Enum.Material.Neon, true, false, 0.1)
				p.Shape = Enum.PartType.Ball
				p.AssemblyLinearVelocity = Vector3.new(math.random(-120, 120), math.random(25, 130), math.random(-120, 120))
				TweenService:Create(p, TweenInfo.new(4.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Transparency = 1,
					Size = Vector3.new(0.2, 0.2, 0.2),
				}):Play()
				Debris:AddItem(p, 4.6)
			end
		end)
	end

	task.delay(5.1, function()
		if creature and creature.Parent then
			creature:Destroy()
		end
		if ROOT_FOLDER and ROOT_FOLDER.Parent then
			ROOT_FOLDER:Destroy()
		end
	end)
end

