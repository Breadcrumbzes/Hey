--!strict
-- Local-player-only chaos creature
-- Put this in StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
while not camera do
	task.wait()
	camera = workspace.CurrentCamera
end

local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid") :: Humanoid
local hrp = character:WaitForChild("HumanoidRootPart") :: BasePart

local ROOT_FOLDER = Instance.new("Folder")
ROOT_FOLDER.Name = "LocalPlayerOnlyChaos"
ROOT_FOLDER.Parent = workspace

local function track<T>(inst: T): T
	return inst
end

local function waitForCharacter()
	character = player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid") :: Humanoid
	hrp = character:WaitForChild("HumanoidRootPart") :: BasePart
end

local function alive(): boolean
	return humanoid.Health > 0 and hrp.Parent ~= nil and character.Parent ~= nil
end

local function randomDirection(): Vector3
	local v = Vector3.new(
		math.random(-100, 100),
		math.random(-35, 35),
		math.random(-100, 100)
	)
	if v.Magnitude < 0.001 then
		v = Vector3.new(1, 0, 0)
	end
	return v.Unit
end

local function playSound(parent: Instance, id: string, volume: number, speed: number?, looped: boolean?): Sound
	local s = Instance.new("Sound")
	s.SoundId = "rbxassetid://" .. id
	s.Volume = volume
	s.PlaybackSpeed = speed or 1
	s.Looped = looped or false
	s.Parent = parent
	s:Play()
	return s
end

local function mkPart(
	size: Vector3,
	cf: CFrame,
	color: Color3,
	material: Enum.Material,
	anchored: boolean,
	canCollide: boolean,
	transparency: number?
): BasePart
	local p = Instance.new("Part")
	p.Size = size
	p.CFrame = cf
	p.Color = color
	p.Material = material
	p.Anchored = anchored
	p.CanCollide = canCollide
	p.CanTouch = true
	p.CanQuery = false
	p.Transparency = transparency or 0
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Parent = ROOT_FOLDER
	return p
end

local function cameraShake(power: number, duration: number)
	local start = os.clock()
	local seed = math.random() * 1000

	local conn
	conn = RunService.RenderStepped:Connect(function()
		if not alive() then
			if conn then conn:Disconnect() end
			return
		end

		local t = os.clock() - start
		if t > duration then
			if conn then conn:Disconnect() end
			return
		end

		local fade = 1 - (t / duration)
		local amt = power * fade
		local nx = (math.noise(seed, t * 18, 0) - 0.5) * amt
		local ny = (math.noise(0, seed, t * 18) - 0.5) * amt
		local nz = (math.noise(t * 18, 0, seed) - 0.5) * amt
		camera.CFrame = camera.CFrame * CFrame.new(nx, ny, nz)
	end)
end

local function makeGhostClone(source: BasePart)
	local ghost = Instance.new("Part")
	ghost.Size = source.Size
	ghost.CFrame = source.CFrame
	ghost.Color = source.Color
	ghost.Material = source.Material
	ghost.Shape = source:IsA("Part") and source.Shape or Enum.PartType.Ball
	ghost.Anchored = true
	ghost.CanCollide = false
	ghost.CanTouch = false
	ghost.CanQuery = false
	ghost.Transparency = 0.75
	ghost.Parent = ROOT_FOLDER

	TweenService:Create(ghost, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = source.Size * 0.95,
	}):Play()

	Debris:AddItem(ghost, 0.4)
end

local function damageLocalPlayer(amount: number)
	if alive() then
		humanoid:TakeDamage(amount)
	end
end

local function localOnlyTouchedDamage(part: BasePart, damageAmount: number, explodeOnTouch: boolean?, boomSoundId: string?)
	local hitOnce = false
	part.Touched:Connect(function(hit)
		if hitOnce then
			return
		end
		if not alive() then
			return
		end
		if hit and hit:IsDescendantOf(character) then
			hitOnce = true
			damageLocalPlayer(damageAmount)

			if explodeOnTouch then
				local pos = part.Position
				local boom = Instance.new("Explosion")
				boom.Position = pos
				boom.BlastRadius = 10
				boom.BlastPressure = 0
				boom.DestroyJointRadiusPercent = 0
				boom.Parent = workspace

				local flash = mkPart(Vector3.new(1, 1, 1), CFrame.new(pos), Color3.fromRGB(255, 140, 40), Enum.Material.Neon, true, false, 0.15)
				flash.Shape = Enum.PartType.Ball
				TweenService:Create(flash, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Transparency = 1,
					Size = Vector3.new(24, 24, 24),
				}):Play()
				Debris:AddItem(flash, 0.3)

				if boomSoundId then
					playSound(flash, boomSoundId, 1.6, 1, false)
				end
			end

			part:Destroy()
		end
	end)
end

local function spawnBlackGoo(origin: Vector3, toward: Vector3)
	local goo = mkPart(Vector3.new(2, 2, 2), CFrame.new(origin), Color3.fromRGB(0, 0, 0), Enum.Material.Neon, true, false, 0.05)
	goo.Shape = Enum.PartType.Ball
	goo.AssemblyLinearVelocity = (toward - origin).Unit * math.random(35, 70) + Vector3.new(math.random(-8, 8), math.random(18, 38), math.random(-8, 8))
	playSound(goo, "109182232826928", 2.5, 1, false)

	local wiped = false
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if wiped or not goo.Parent then
			if conn then conn:Disconnect() end
			return
		end
		if not alive() then
			if conn then conn:Disconnect() end
			goo:Destroy()
			return
		end
	end)

	local touchedConn
	touchedConn = goo.Touched:Connect(function(hit)
		if wiped then
			return
		end
		if hit and hit:IsDescendantOf(character) then
			wiped = true
			damageLocalPlayer(28)
			if touchedConn then touchedConn:Disconnect() end
			goo:Destroy()
		end
	end)

	TweenService:Create(goo, TweenInfo.new(5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = goo.Size * 0.2,
	}):Play()
	Debris:AddItem(goo, 5.1)
end

local function spawnRedExplosiveBall(origin: Vector3, target: Vector3)
	local ball = mkPart(Vector3.new(2.2, 2.2, 2.2), CFrame.new(origin), Color3.fromRGB(255, 40, 40), Enum.Material.Neon, true, true, 0.05)
	ball.Shape = Enum.PartType.Ball
	local light = Instance.new("PointLight")
	light.Range = 18
	light.Brightness = 3
	light.Color = Color3.fromRGB(255, 80, 80)
	light.Parent = ball

	local dir = (target - origin)
	if dir.Magnitude < 0.001 then
		dir = Vector3.new(0, 1, 0)
	end
	dir = dir.Unit

	local hit = false
	local conn
	conn = RunService.Heartbeat:Connect(function(dt)
		if not ball.Parent then
			if conn then conn:Disconnect() end
			return
		end
		if not alive() then
			if conn then conn:Disconnect() end
			ball:Destroy()
			return
		end

		ball.CFrame = ball.CFrame + (dir * (115 * dt))

		if hrp and (ball.Position - hrp.Position).Magnitude < 4 and not hit then
			hit = true
			playSound(ball, "140615626179933", 1.8, 1, false)
			damageLocalPlayer(11)

			local boom = Instance.new("Explosion")
			boom.Position = ball.Position
			boom.BlastRadius = 8
			boom.BlastPressure = 0
			boom.DestroyJointRadiusPercent = 0
			boom.Parent = workspace

			local flash = mkPart(Vector3.new(1, 1, 1), CFrame.new(ball.Position), Color3.fromRGB(255, 30, 30), Enum.Material.Neon, true, false, 0.1)
			flash.Shape = Enum.PartType.Ball
			TweenService:Create(flash, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Transparency = 1,
				Size = Vector3.new(18, 18, 18),
			}):Play()
			Debris:AddItem(flash, 0.25)

			ball:Destroy()
			if conn then conn:Disconnect() end
		end
	end)

	Debris:AddItem(ball, 4.5)
end

