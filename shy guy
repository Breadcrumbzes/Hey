local function stopAllMusic()
	for _, sound in pairs(phaseSounds) do
		pcall(function()
			sound.Volume = 0
			sound:Stop()
		end)
	end
end

local function cleanupAll()
	if cleanupDone then
		return
	end
	cleanupDone = true

	for _, conn in ipairs(connections) do
		pcall(function()
			conn:Disconnect()
		end)
	end
	table.clear(connections)

	stopAllMusic()

	if redGui then
		redGui:Destroy()
		redGui = nil
		redFrame = nil
	end

	if chaosFolder and chaosFolder.Parent then
		chaosFolder:Destroy()
	end

	if musicFolder and musicFolder.Parent then
		musicFolder:Destroy()
	end
end

local function beginShutdown(isWin: boolean?)
	if shuttingDown then
		return
	end
	shuttingDown = true
	running = false

	stopAllMusic()

	if isWin then
		createGreenFlash()
	else
		createRedFlash()
	end

	task.delay(0.55, function()
		cleanupAll()
	end)
end

