--!strict
-- Ultra-chaos LocalScript
-- Put in StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local DURATION = 60
local START_TIME = os.clock()

local SND = {
	Explosion = "rbxassetid://140615626179933",
	Shriek = "rbxassetid://135049904093550",
	Horn = "rbxassetid://121533907629378",
	Worm = "rbxassetid://111993673815478",
	Missile = "rbxassetid://113032480637316",
}

local function alive(): boolean
	return os.clock() - START_TIME < DURATION
end

local function getCharacter()
	local char = player.Character or player.CharacterAdded:Wait()
	local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart")
	return char, hum, hrp
end

local character, humanoid, hrp = getCharacter()

local chaosFolder = Instance.new("Folder")
chaosFolder.Name = "UltraChaoticLocalHell"
chaosFolder.Parent = workspace

local function mkSound(id: string, parent: Instance, volume: number, speed: number?, looped: boolean?)
	local s = Instance.new("Sound")
	s.SoundId = id
	s.Volume = volume
	s.PlaybackSpeed = speed or 1
	s.Looped = looped or false
	s.Parent = parent
	s:Play()
	return s
end

local function mkPart(
	size: Vector3,
	cf: CFrame,
	color: Color3,
	material: Enum.Material,
	anchored: boolean,
	canCollide: boolean,
	transparency: number?
)
	local p = Instance.new("Part")
	p.Size = size
	p.CFrame = cf
	p.Color = color
	p.Material = material
	p.Anchored = anchored
	p.CanCollide = canCollide
	p.CanTouch = false
	p.CanQuery = false
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.Transparency = transparency or 0
	p.Parent = chaosFolder
	return p
end

local function applyLocalDamage(amount: number)
	if humanoid and humanoid.Parent then
		humanoid:TakeDamage(amount)
	end
end

local function applyKnockback(direction: Vector3, force: number)
	if hrp and hrp.Parent then
		local bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
		bv.P = 12500
		bv.Velocity = direction.Unit * force + Vector3.new(0, math.random(8, 30), 0)
		bv.Parent = hrp
		Debris:AddItem(bv, 0.14)
	end
end

local function explosionFlash(pos: Vector3, radius: number, pressure: number)
	local boom = Instance.new("Explosion")
	boom.Position = pos
	boom.BlastRadius = radius
	boom.BlastPressure = pressure
	boom.DestroyJointRadiusPercent = 0
	boom.Parent = workspace

	local flash = mkPart(Vector3.new(1, 1, 1), CFrame.new(pos), Color3.new(1, 0.75, 0.2), Enum.Material.Neon, true, false, 0.25)
	flash.Shape = Enum.PartType.Ball

	local scale = radius * 6
	TweenService:Create(flash, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(scale, scale, scale),
	}):Play()

	mkSound(SND.Explosion, flash, 2, 0.9 + math.random() * 0.25, false)
	Debris:AddItem(flash, 0.5)
	return boom
end

local function shockwave(pos: Vector3, startSize: number, endSize: number, color: Color3, life: number)
	local wave = mkPart(Vector3.new(startSize, startSize, startSize), CFrame.new(pos), color, Enum.Material.Neon, true, false, 0.4)
	wave.Shape = Enum.PartType.Ball
	TweenService:Create(wave, TweenInfo.new(life, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(endSize, endSize, endSize),
	}):Play()
	Debris:AddItem(wave, life + 0.05)
end

local function mushroomCloud(pos: Vector3)
	local stem = mkPart(Vector3.new(8, 18, 8), CFrame.new(pos), Color3.fromRGB(210, 180, 120), Enum.Material.SmoothPlastic, true, false, 0.1)
	stem.Shape = Enum.PartType.Cylinder
	stem.CFrame = CFrame.new(pos + Vector3.new(0, 8, 0)) * CFrame.Angles(0, 0, math.rad(90))

	local cap = mkPart(Vector3.new(18, 18, 18), CFrame.new(pos + Vector3.new(0, 18, 0)), Color3.fromRGB(255, 140, 40), Enum.Material.Neon, true, false, 0.2)
	cap.Shape = Enum.PartType.Ball

	local cap2 = mkPart(Vector3.new(28, 10, 28), CFrame.new(pos + Vector3.new(0, 24, 0)), Color3.fromRGB(120, 120, 120), Enum.Material.SmoothPlastic, true, false, 0.35)
	cap2.Shape = Enum.PartType.Ball

	TweenService:Create(stem, TweenInfo.new(2.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(12, 40, 12),
		CFrame = stem.CFrame + Vector3.new(0, 18, 0),
	}):Play()

	TweenService:Create(cap, TweenInfo.new(2.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(34, 34, 34),
		CFrame = cap.CFrame + Vector3.new(0, 18, 0),
	}):Play()

	TweenService:Create(cap2, TweenInfo.new(2.8, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Transparency = 1,
		Size = Vector3.new(48, 20, 48),
		CFrame = cap2.CFrame + Vector3.new(0, 30, 0),
	}):Play()

	Debris:AddItem(stem, 3)
	Debris:AddItem(cap, 3)
	Debris:AddItem(cap2, 3)

	mkSound(SND.Explosion, stem, 1.5, 0.8, false)
	mkSound(SND.Horn, cap, 1.1, 1, false)
end

local function createProjectile(origin: Vector3, target: Vector3, speed: number, radius: number, damage: number)
	local proj = mkPart(Vector3.new(radius, radius, radius), CFrame.new(origin), Color3.fromRGB(255, 60, 60), Enum.Material.Neon, true, false, 0)
	proj.Shape = Enum.PartType.Ball

	local a0 = Instance.new("Attachment", proj)
	local a1 = Instance.new("Attachment", proj)
	a0.Position = Vector3.new(0, radius * 0.5, 0)
	a1.Position = Vector3.new(0, -radius * 0.5, 0)

	local trail = Instance.new("Trail")
	trail.Attachment0 = a0
	trail.Attachment1 = a1
	trail.Lifetime = 0.22
	trail.MinLength = 0.05
	trail.Parent = proj

	mkSound(SND.Missile, proj, 1.4, 1 + math.random(-15, 15) / 100, false)

	local dir = (target - origin)
	if dir.Magnitude < 0.01 then
		dir = Vector3.new(0, 0, -1)
	end
	dir = dir.Unit

	local life = 0
	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not proj.Parent then
			if conn then conn:Disconnect() end
			if proj.Parent then proj:Destroy() end
			return
		end

		life += dt
		proj.CFrame = proj.CFrame + (dir * speed * dt)

		if hrp and hrp.Parent and (proj.Position - hrp.Position).Magnitude < 5 then
			local hitPos = proj.Position
			explosionFlash(hitPos, 10 + radius * 5, 650000)
			shockwave(hitPos, 4, 25, Color3.new(1, 0.6, 0.2), 0.35)
			applyLocalDamage(damage)
			applyKnockback(hrp.Position - hitPos, 80 + radius * 22)
			if math.random() < 0.35 then
				mushroomCloud(hitPos)
			end
			if conn then conn:Disconnect() end
			proj:Destroy()
			return
		end

		if life > 7 then
			if conn then conn:Disconnect() end
			proj:Destroy()
		end
	end)
end

local function createCubeDrone(spawnOffset: Vector3, size: number, speed: number, damage: number)
	local cube = mkPart(Vector3.new(size, size, size), hrp.CFrame * CFrame.new(spawnOffset), Color3.fromRGB(math.random(80, 255), math.random(20, 120), math.random(20, 120)), Enum.Material.Metal, true, false, 0)
	cube.Shape = Enum.PartType.Block
	mkSound(SND.Worm, cube, 0.8, 0.9 + math.random() * 0.25, true)

	local spin = Vector3.new(math.random(-15, 15), math.random(-15, 15), math.random(-15, 15))
	local t = 0
	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not cube.Parent or not hrp.Parent then
			if conn then conn:Disconnect() end
			if cube.Parent then cube:Destroy() end
			return
		end

		t += dt
		local orbitRadius = 18 + math.sin(t * 4) * 8
		local angle = t * (2.6 + math.random() * 1.6)
		local goal = hrp.Position + Vector3.new(math.cos(angle) * orbitRadius, math.sin(t * 6) * 4 + 3, math.sin(angle) * orbitRadius)
		local stepDir = (goal - cube.Position)
		if stepDir.Magnitude > 0.1 then
			cube.CFrame = CFrame.new(cube.Position + stepDir.Unit * speed * dt, hrp.Position) * CFrame.Angles(math.rad(spin.X * dt), math.rad(spin.Y * dt), math.rad(spin.Z * dt))
		end

		if (cube.Position - hrp.Position).Magnitude < 5 then
			local hitPos = cube.Position
			explosionFlash(hitPos, 7, 280000)
			shockwave(hitPos, 3, 18, Color3.new(1, 1, 1), 0.25)
			applyLocalDamage(damage)
			applyKnockback(hrp.Position - hitPos, 65)
			if math.random() < 0.5 then
				mushroomCloud(hitPos)
			end
			if conn then conn:Disconnect() end
			cube:Destroy()
			return
		end

		if t > 10 then
			explosionFlash(cube.Position, 5, 120000)
			if conn then conn:Disconnect() end
			cube:Destroy()
		end
	end)

	return cube
end

local function swarmOfCubes(count: number)
	for i = 1, count do
		local theta = (i / count) * math.pi * 2
		local offset = Vector3.new(math.cos(theta) * (25 + math.random(-5, 5)), math.random(-2, 12), math.sin(theta) * (25 + math.random(-5, 5)))
		createCubeDrone(offset, math.random(2, 5), 15 + math.random(0, 15), math.random(1, 6))
	end
end

local function missileRing(count: number)
	for i = 1, count do
		local theta = (i / count) * math.pi * 2
		local origin = hrp.Position + Vector3.new(math.cos(theta) * 50, 20 + math.random(-10, 12), math.sin(theta) * 50)
		local target = hrp.Position + Vector3.new(math.random(-2, 2), math.random(-1, 4), math.random(-2, 2))
		createProjectile(origin, target, 100 + math.random(0, 80), math.random(2, 4), math.random(2, 8))
	end
end

local function missileStorm()
	for i = 1, math.random(10, 18) do
		task.delay(i * 0.05, function()
			if not alive() then return end
			local origin = hrp.Position + Vector3.new(math.random(-70, 70), math.random(25, 55), math.random(-70, 70))
			createProjectile(origin, hrp.Position + Vector3.new(math.random(-3, 3), math.random(-1, 5), math.random(-3, 3)), 130 + math.random(0, 60), 3, math.random(2, 8))
		end)
	end
end

local function explosionRain()
	for i = 1, math.random(5, 12) do
		task.delay(math.random() * 0.7, function()
			if not alive() then return end
			local pos = hrp.Position + Vector3.new(math.random(-30, 30), math.random(8, 28), math.random(-30, 30))
			explosionFlash(pos, 10 + math.random(0, 7), 240000)
			if math.random() < 0.35 then
				mushroomCloud(pos)
			end
		end)
	end
end

local function orbitingSatelliteSpawner(index: number)
	local sat = mkPart(Vector3.new(3, 3, 3), hrp.CFrame, Color3.fromRGB(255, 255, 255), Enum.Material.Neon, true, false, 0.15)
	sat.Shape = Enum.PartType.Ball
	local beam = Instance.new("PointLight")
	beam.Range = 16
	beam.Brightness = 2
	beam.Parent = sat

	local ang = index * (math.pi * 2 / 8)
	local radius = 14 + (index % 3) * 6
	local life = 0

	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not sat.Parent or not hrp.Parent then
			if conn then conn:Disconnect() end
			if sat.Parent then sat:Destroy() end
			return
		end

		life += dt
		ang += dt * (1.5 + index * 0.08)

		local orbitPos = hrp.Position + Vector3.new(math.cos(ang) * radius, math.sin(life * 3) * 5 + 8, math.sin(ang) * radius)
		sat.CFrame = CFrame.new(orbitPos)

		if math.floor(life * 6) % 4 == 0 then
			if math.random() < 0.28 then
				createProjectile(orbitPos, hrp.Position + Vector3.new(math.random(-2, 2), math.random(-1, 3), math.random(-2, 2)), 115, 2, 2)
			end
		end

		if math.random() < 0.02 then
			explosionFlash(orbitPos, 4, 50000)
		end
	end)

	return sat
end

local function buildSatelliteNet()
	for i = 1, 8 do
		orbitingSatelliteSpawner(i)
	end
end

local function cameraShake(intensity: number, rate: number)
	local t = 0
	local conn: RBXScriptConnection?
	conn = RunService.RenderStepped:Connect(function(dt)
		if not alive() or not camera or not hrp.Parent then
			if conn then conn:Disconnect() end
			return
		end
		t += dt * rate
		camera.CFrame = camera.CFrame * CFrame.new(
			(math.noise(t, 1, 1) - 0.5) * intensity,
			(math.noise(1, t, 1) - 0.5) * intensity,
			(math.noise(1, 1, t) - 0.5) * intensity
		)
	end)
end

local function screenChaos()
	local blur = Instance.new("BlurEffect")
	blur.Size = 0
	blur.Parent = Lighting

	local cc = Instance.new("ColorCorrectionEffect")
	cc.Brightness = 0
	cc.Contrast = 0
	cc.Saturation = 0
	cc.TintColor = Color3.fromRGB(255, 200, 180)
	cc.Parent = Lighting

	TweenService:Create(blur, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = 18 }):Play()
	TweenService:Create(cc, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Brightness = 0.15,
		Contrast = 0.25,
		Saturation = -0.2,
	}):Play()

	Debris:AddItem(blur, DURATION + 1)
	Debris:AddItem(cc, DURATION + 1)
end

local function warningHorn()
	mkSound(SND.Horn, hrp, 1.5, 1, false)
end

local function shriek()
	mkSound(SND.Shriek, hrp, 1.2, 1 + math.random(-8, 8) / 100, false)
end

local function wormBuzz()
	mkSound(SND.Worm, hrp, 0.9, 0.85 + math.random() * 0.3, false)
end

local function localNukeSequence()
	local pos = hrp.Position + Vector3.new(math.random(-6, 6), math.random(0, 4), math.random(-6, 6))
	explosionFlash(pos, 16, 700000)
	shockwave(pos, 10, 120, Color3.fromRGB(255, 180, 80), 0.8)
	mushroomCloud(pos)
	applyLocalDamage(math.random(3, 8))
	applyKnockback(Vector3.new(math.random(-1, 1), 1, math.random(-1, 1)), 110)
end

screenChaos()
cameraShake(0.05, 18)
buildSatelliteNet()
warningHorn()

task.spawn(function()
	while alive() do
		task.wait(0.22)
		if not alive() then break end

		local mode = math.random(1, 7)

		if mode == 1 then
			swarmOfCubes(math.random(8, 20))
		elseif mode == 2 then
			missileRing(math.random(8, 16))
		elseif mode == 3 then
			explosionRain()
		elseif mode == 4 then
			missileStorm()
		elseif mode == 5 then
			shriek()
		elseif mode == 6 then
			wormBuzz()
		elseif mode == 7 then
			localNukeSequence()
		end

		if math.random() < 0.45 then
			createProjectile(
				hrp.Position + Vector3.new(math.random(-55, 55), math.random(18, 45), math.random(-55, 55)),
				hrp.Position + Vector3.new(math.random(-3, 3), math.random(-1, 5), math.random(-3, 3)),
				140 + math.random(0, 40),
				math.random(2, 4),
				math.random(1, 6)
			)
		end

		if math.random() < 0.2 then
			mushroomCloud(hrp.Position + Vector3.new(math.random(-10, 10), 0, math.random(-10, 10)))
		end
	end
end)

