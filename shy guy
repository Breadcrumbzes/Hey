			end)
		end)
	end
end

local function spawnSpinningWhiteSquares(center: Vector3, count: number)
	for i = 1, count do
		local part = mkPart(Vector3.new(0.9, 0.9, 0.9), CFrame.new(center), Color3.fromRGB(255, 255, 255), Enum.Material.Neon, true, false, 0)
		part.Shape = Enum.PartType.Block

		local dir = (Vector3.new(math.random(-100, 100), math.random(-10, 100), math.random(-100, 100)))
		if dir.Magnitude < 0.001 then
			dir = Vector3.new(1, 1, 0)
		end
		dir = dir.Unit
		local speed = math.random(55, 105)
		local life = 0
		local spin = Vector3.new(math.random(-900, 900), math.random(-900, 900), math.random(-900, 900))

		local conn: RBXScriptConnection?
		conn = RunService.Heartbeat:Connect(function(dt)
			if not part.Parent or not alive() then
				if conn then
					conn:Disconnect()
				end
				if part.Parent then
					part:Destroy()
				end
				return
			end

			life += dt
			part.CFrame = part.CFrame
				+ dir * speed * dt
				* CFrame.Angles(math.rad(spin.X * dt), math.rad(spin.Y * dt), math.rad(spin.Z * dt))

			if hrp and hrp.Parent and (part.Position - hrp.Position).Magnitude < 4.5 then
				explosionFlash(part.Position, 5, 90000)
				if conn then
					conn:Disconnect()
				end
				part:Destroy()
				return
			end

			if life > 2.5 then
				if conn then
					conn:Disconnect()
				end
				part:Destroy()
			end
		end)

		Debris:AddItem(part, 3)
	end
end

local function apocalypseDashOrb(orb: BasePart)
	local startPos = orb.Position
	local targetPos = hrp.Position + Vector3.new(math.random(-6, 6), math.random(-1, 4), math.random(-6, 6))
	local dashTime = 0.6 + math.random() * 0.35
	local elapsed = 0
	local hit = false

	orb.Material = Enum.Material.Neon
	orb.Color = Color3.fromRGB(255, 80, 60)

	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not orb.Parent or not hrp.Parent then
			if conn then
				conn:Disconnect()
			end
			return
		end

		elapsed += dt
		local alpha = math.clamp(elapsed / dashTime, 0, 1)
		local pos = startPos:Lerp(targetPos, alpha)
		orb.CFrame = CFrame.new(pos)

		if (orb.Position - hrp.Position).Magnitude < 5.5 and not hit then
			hit = true
			local impact = orb.Position
			explosionFlash(impact, 10, 220000)
			shockwave(impact, 8, 32, Color3.fromRGB(255, 150, 40), 0.35)
			applyLocalDamage(math.random(1, 5))
			applyKnockback(hrp.Position - impact, 70 + math.random(0, 25))
			if conn then
				conn:Disconnect()
			end
		end

		if elapsed >= dashTime then
			if not hit then
				local impact = orb.Position
				explosionFlash(impact, 8, 180000)
				shockwave(impact, 7, 28, Color3.fromRGB(255, 140, 35), 0.35)
			end
			if conn then
				conn:Disconnect()
			end
		end
	end)

	task.wait(dashTime + 0.1)
	orb.Color = Color3.fromRGB(255, 70, 70)
end

local function apocalypseSpewOrb(orb: BasePart)
	orb.Material = Enum.Material.Neon
	orb.Color = Color3.fromRGB(255, 60, 70)

	local burstCount = math.random(18, 34)
	for i = 1, burstCount do
		task.delay((i - 1) * 0.03, function()
			if not alive() or not orb.Parent then
				return
			end

			local origin = orb.Position + Vector3.new(math.random(-3, 3), math.random(-3, 3), math.random(-3, 3))
			local target = hrp.Position + Vector3.new(math.random(-5, 5), math.random(-1, 4), math.random(-5, 5))
			local radius = math.random(1, 2)
			local speed = 105 + math.random(0, 75)

			local proj = mkPart(Vector3.new(radius, radius, radius), CFrame.new(origin), Color3.fromRGB(255, 80, 80), Enum.Material.Neon, true, false, 0)
			proj.Shape = Enum.PartType.Ball

			local a0 = Instance.new("Attachment")
			a0.Position = Vector3.new(0, radius * 0.5, 0)
			a0.Parent = proj

			local a1 = Instance.new("Attachment")
			a1.Position = Vector3.new(0, -radius * 0.5, 0)
			a1.Parent = proj

			local trail = Instance.new("Trail")
			trail.Attachment0 = a0
			trail.Attachment1 = a1
			trail.Lifetime = 0.15
			trail.MinLength = 0.1
			trail.Parent = proj

			mkSound(SND.Missile, proj, 0.55, 0.95 + math.random() * 0.2, false)

			local dir = target - origin
			if dir.Magnitude < 0.001 then
				dir = Vector3.new(0, 0, -1)
			end
			dir = dir.Unit

			local life = 0
			local conn: RBXScriptConnection?
			conn = RunService.Heartbeat:Connect(function(dt)
				if not alive() or not proj.Parent then
					if conn then
						conn:Disconnect()
					end
					if proj.Parent then
						proj:Destroy()
					end
					return
				end

				life += dt
				proj.CFrame = proj.CFrame + dir * speed * dt

				if hrp and hrp.Parent and (proj.Position - hrp.Position).Magnitude < 4.0 then
					local hitPos = proj.Position
					explosionFlash(hitPos, 7, 110000)
					shockwave(hitPos, 3, 14, Color3.fromRGB(255, 200, 80), 0.2)
					applyLocalDamage(math.random(1, 3))
					if conn then
						conn:Disconnect()
					end
					proj:Destroy()
					return
				end

				if life > 6 then
					if conn then
						conn:Disconnect()
					end
					proj:Destroy()
				end
			end)
		end)
	end

	task.wait(0.35)
	orb.Color = Color3.fromRGB(255, 70, 70)
end

local function apocalypseFreezeOrb(orb: BasePart)
	local origin = orb.Position
	orb.Material = Enum.Material.Neon
	orb.Color = Color3.fromRGB(255, 255, 255)

	local light = orb:FindFirstChildOfClass("PointLight")
	if light then
		light.Color = Color3.fromRGB(255, 255, 255)
		light.Brightness = 7
		light.Range = 36
	end

	task.wait(0.75)
	if not alive() or not orb.Parent then
		return
	end

	local center = orb.Position
	explosionFlash(center, 22, 700000)
	shockwave(center, 12, 100, Color3.fromRGB(255, 255, 255), 0.9)
	spawnSpinningWhiteSquares(center, math.random(26, 42))
	applyLocalDamage(math.random(2, 5))
	applyKnockback(hrp.Position - center, 90)

	task.wait(0.35)
	if orb.Parent then
		orb.Color = Color3.fromRGB(255, 70, 70)
		if light then
			light.Color = Color3.fromRGB(255, 60, 60)
			light.Brightness = 2.5
			light.Range = 24
		end
	end
end

local function createApocalypseOrb(index: number)
	local orb = mkPart(Vector3.new(10, 10, 10), hrp.CFrame, Color3.fromRGB(255, 70, 70), Enum.Material.Neon, true, false, 0.05)
	orb.Shape = Enum.PartType.Ball

	local light = Instance.new("PointLight")
	light.Color = Color3.fromRGB(255, 70, 70)
	light.Range = 24
	light.Brightness = 2.5
	light.Parent = orb

	local angle = index * (math.pi * 2 / 5)
	local radius = 40 + (index % 3) * 10
	local busy = false
	local orbitLife = 0

	local orbitConn: RBXScriptConnection?
	orbitConn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not orb.Parent or not hrp.Parent then
			if orbitConn then
				orbitConn:Disconnect()
			end
			if orb.Parent then
				orb:Destroy()
			end
			return
		end

		orbitLife += dt
		if not busy and currentPhase() == "Apocalypse" then
			angle += dt * (0.55 + index * 0.05)
			local y = 18 + math.sin(orbitLife * 2.2 + index) * 7
			local pos = hrp.Position + Vector3.new(math.cos(angle) * radius, y, math.sin(angle) * radius)
			orb.CFrame = CFrame.new(pos)
			orb.Color = Color3.fromRGB(255, 70, 70)
			light.Color = Color3.fromRGB(255, 70, 70)
			light.Brightness = 2.5 + math.sin(orbitLife * 8) * 0.5
		end
	end)

	table.insert(apocalypseOrbConnections, orbitConn)

	task.spawn(function()
		while alive() and orb.Parent do
			if currentPhase() ~= "Apocalypse" then
				task.wait(0.2)
				continue
			end

			task.wait(0.9 + math.random() * 1.8)
			if not alive() or not orb.Parent or currentPhase() ~= "Apocalypse" then
				continue
			end

			busy = true
			local choice = math.random(1, 3)

			if choice == 1 then
				apocalypseDashOrb(orb)
			elseif choice == 2 then
				apocalypseSpewOrb(orb)
			else
				apocalypseFreezeOrb(orb)
			end

			busy = false
		end
	end)
end

local function buildApocalypseOrbs()
	if apocalypseOrbsBuilt then
		return
	end
	apocalypseOrbsBuilt = true

	for i = 1, 5 do
		createApocalypseOrb(i)
	end
end

local function cameraShake(intensity: number, rate: number)
	local t = 0
	local conn: RBXScriptConnection?
	conn = RunService.RenderStepped:Connect(function(dt)
		if not alive() or not camera or not hrp.Parent then
			if conn then
				conn:Disconnect()
			end
			return
		end
		t += dt * rate
		local p = progress()
		local amount = intensity * (0.2 + p * 1.2)
		camera.CFrame = camera.CFrame * CFrame.new(
			(math.noise(t, 1, 1) - 0.5) * amount,
			(math.noise(1, t, 1) - 0.5) * amount,
			(math.noise(1, 1, t) - 0.5) * amount
		)
	end)
end

local function screenChaos()
	local blur = Instance.new("BlurEffect")
	blur.Size = 0
	blur.Parent = Lighting

	local cc = Instance.new("ColorCorrectionEffect")
	cc.Brightness = 0
	cc.Contrast = 0
	cc.Saturation = 0
	cc.TintColor = Color3.fromRGB(255, 220, 200)
	cc.Parent = Lighting

	TweenService:Create(blur, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = 14 }):Play()
	TweenService:Create(cc, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Brightness = 0.08,
		Contrast = 0.18,
		Saturation = -0.1,
	}):Play()

	Debris:AddItem(blur, DURATION + 2)
	Debris:AddItem(cc, DURATION + 2)
end

