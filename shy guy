local function whiteShardBurst(pos: Vector3)
	for i = 1, 28 do
		local shard = mkPart(
			Vector3.new(0.7, 0.7, 0.7),
			CFrame.new(pos),
			Color3.fromRGB(255, 255, 255),
			Enum.Material.Neon,
			true,
			false,
			0
		)
		shard.Shape = Enum.PartType.Block

		local dir = Vector3.new(
			math.random(-100, 100) / 100,
			math.random(20, 100) / 100,
			math.random(-100, 100) / 100
		)
		if dir.Magnitude < 0.01 then
			dir = Vector3.new(0, 1, 0)
		end
		dir = dir.Unit

		local spin = Vector3.new(math.random(-20, 20), math.random(-20, 20), math.random(-20, 20))
		local life = 0

		local conn: RBXScriptConnection?
		conn = RunService.Heartbeat:Connect(function(dt)
			if not shard.Parent or not alive() then
				if conn then
					conn:Disconnect()
				end
				if shard.Parent then
					shard:Destroy()
				end
				return
			end

			life += dt
			shard.CFrame = shard.CFrame
				* CFrame.new(dir * (90 * dt))
				* CFrame.Angles(math.rad(spin.X * dt), math.rad(spin.Y * dt), math.rad(spin.Z * dt))

			if hrp and hrp.Parent and (shard.Position - hrp.Position).Magnitude < 4 then
				explosionFlash(shard.Position, 3, 55000)
				applyLocalDamage(1)
				if conn then
