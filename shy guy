local redGui: ScreenGui? = nil
local redFrame: Frame? = nil

local function createShutdownFlash(flashColor: Color3)
	if redGui then
		redGui:Destroy()
	end

	redGui = Instance.new("ScreenGui")
	redGui.Name = "ShutdownFlashGui"
	redGui.IgnoreGuiInset = true
	redGui.ResetOnSpawn = false
	redGui.DisplayOrder = 999999
	redGui.Parent = PlayerGui

	redFrame = Instance.new("Frame")
	redFrame.Size = UDim2.fromScale(1, 1)
	redFrame.BackgroundColor3 = flashColor
	redFrame.BackgroundTransparency = 1
	redFrame.BorderSizePixel = 0
	redFrame.Parent = redGui

	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 0
	stroke.Transparency = 1
	stroke.Parent = redFrame

	TweenService:Create(redFrame, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.2,
	}):Play()

	task.delay(0.12, function()
		if redFrame and redFrame.Parent then
			TweenService:Create(redFrame, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				BackgroundTransparency = 1,
			}):Play()
		end
	end)
end

local function stopAllMusic()
	for _, sound in pairs(phaseSounds) do
		pcall(function()
			sound.Volume = 0
			sound:Stop()
		end)
	end
end

local function cleanupAll()
	if cleanupDone then
		return
	end
	cleanupDone = true

	for _, conn in ipairs(connections) do
		pcall(function()
			conn:Disconnect()
		end)
	end
	table.clear(connections)

	stopAllMusic()

	if redGui then
		redGui:Destroy()
		redGui = nil
		redFrame = nil
	end

	if chaosFolder and chaosFolder.Parent then
		chaosFolder:Destroy()
	end

	if musicFolder and musicFolder.Parent then
		musicFolder:Destroy()
	end
end

local function beginShutdown(won: boolean)
	if shuttingDown then
		return
	end
	shuttingDown = true
	running = false

	stopAllMusic()

	if won then
		createShutdownFlash(Color3.fromRGB(70, 255, 110))
	else
		createShutdownFlash(Color3.fromRGB(255, 0, 0))
	end

	task.delay(0.55, function()
		cleanupAll()
	end)
end

track(humanoid.Died:Connect(function()
	beginShutdown(false)
end))

screenChaos()
cameraShake(0.035, 10)
buildSatelliteNet()
warningHorn()

track(RunService.RenderStepped:Connect(function()
	if shuttingDown then
		return
	end

	local phase = currentPhase()
	playPhaseMusic(phase)
end))

local function spawnWhiteSquareParticle(origin: Vector3, target: Vector3, speed: number, size: number, damage: number)
	local part = mkPart(Vector3.new(size, size, size), CFrame.new(origin), Color3.fromRGB(255, 255, 255), Enum.Material.Neon, true, false, 0.1)
	part.Shape = Enum.PartType.Block

	local spin = Vector3.new(math.random(-20, 20), math.random(-20, 20), math.random(-20, 20))
	local dir = (target - origin)
	if dir.Magnitude < 0.001 then
		dir = Vector3.new(0, 1, 0)
	end
	dir = dir.Unit

	mkSound(SND.Missile, part, 0.8, 1.1, false)

	local life = 0
	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not part.Parent then
			if conn then
				conn:Disconnect()
			end
			if part.Parent then
				part:Destroy()
			end
			return
		end

		life += dt
		part.CFrame = part.CFrame * CFrame.Angles(math.rad(spin.X * dt), math.rad(spin.Y * dt), math.rad(spin.Z * dt))
		part.CFrame = CFrame.new(part.Position + dir * speed * dt) * (part.CFrame - part.CFrame.Position)

		if hrp and hrp.Parent and (part.Position - hrp.Position).Magnitude < 4 then
			local hitPos = part.Position
			explosionFlash(hitPos, 4, 60000)
			shockwave(hitPos, 2, 10, Color3.fromRGB(255, 255, 255), 0.18)
			applyLocalDamage(damage)
			if conn then
				conn:Disconnect()
			end
			part:Destroy()
			return
		end

		if life > 7 then
			if conn then
				conn:Disconnect()
			end
			part:Destroy()
		end
	end)
end

local function spewNeonSpheres(origin: Vector3, target: Vector3, count: number)
	for i = 1, count do
		task.delay((i - 1) * 0.04, function()
			if not alive() then
				return
			end

			local spread = Vector3.new(
				math.random(-10, 10),
				math.random(-6, 8),
				math.random(-10, 10)
			)

			local sphereOrigin = origin + spread * 0.5
			local sphereTarget = target + Vector3.new(math.random(-5, 5), math.random(-2, 5), math.random(-5, 5))
			createProjectile(sphereOrigin, sphereTarget, 95 + math.random(0, 35), 1.5, math.random(1, 3))
		end)
	end
end

local function whiteExplosionBurst(origin: Vector3)
	for i = 1, 20 do
		local theta = (i / 20) * math.pi * 2
		local up = (i % 5) * 1.5
		local offset = Vector3.new(math.cos(theta) * 6, up, math.sin(theta) * 6)
		spawnWhiteSquareParticle(origin + offset, origin + offset + Vector3.new(math.random(-18, 18), math.random(8, 26), math.random(-18, 18)), 90 + math.random(0, 60), math.random(1, 2), 2)
	end
end

local function spawnApocalypseRedOrb(index: number)
	local spawnPos = hrp.Position + Vector3.new(math.random(-65, 65), math.random(18, 40), math.random(-65, 65))
	local orb = mkPart(Vector3.new(8, 8, 8), CFrame.new(spawnPos), Color3.fromRGB(220, 20, 20), Enum.Material.Neon, true, false, 0.1)
	orb.Shape = Enum.PartType.Ball

	local light = Instance.new("PointLight")
	light.Color = Color3.fromRGB(255, 40, 40)
	light.Range = 28
	light.Brightness = 2.5
	light.Parent = orb

	local promptSound = mkSound(SND.Worm, orb, 0.5, 0.95 + math.random() * 0.2, true)

	local state = "orbit" -- orbit | telegraph_dash | dash | telegraph_spew | spew | telegraph_freeze | freeze
	local nextActionTime = os.clock() + math.random(2, 5)
	local actionEndTime = 0.0
	local dashTarget = Vector3.zero
	local orbitAngle = (index / 5) * math.pi * 2 + math.random() * 0.75
	local orbitRadius = 58 + index * 5
	local dashSpeed = 120
	local spewEndTime = 0.0
	local spewLastShot = 0.0
	local freezeLastSpark = 0.0
	local freezeEndTime = 0.0
	local orbitHeight = 18 + index * 2

	local function resetToOrbit()
		state = "orbit"
		nextActionTime = os.clock() + math.random(2, 5)
		orb.Color = Color3.fromRGB(220, 20, 20)
		light.Color = Color3.fromRGB(255, 40, 40)
		light.Brightness = 2.5
		orb.Transparency = 0.1
		pcall(function()
			promptSound.PlaybackSpeed = 0.95 + math.random() * 0.2
		end)
	end

	local conn: RBXScriptConnection?
	conn = RunService.Heartbeat:Connect(function(dt)
		if not alive() or not orb.Parent or not hrp.Parent then
			if conn then
				conn:Disconnect()
			end
			if orb.Parent then
				orb:Destroy()
			end
			return
		end

		local now = os.clock()
		local targetPos = hrp.Position

		if state == "orbit" then
			orbitAngle += dt * (0.8 + index * 0.08)
			local waveY = math.sin(now * 2.2 + index) * 6
			local orbitPos = targetPos + Vector3.new(math.cos(orbitAngle) * orbitRadius, orbitHeight + waveY, math.sin(orbitAngle) * orbitRadius)
			orb.CFrame = CFrame.new(orb.Position:Lerp(orbitPos, math.clamp(dt * 4, 0, 1)), targetPos)

			if now >= nextActionTime and progress() > 0.75 then
				local choice = math.random(1, 3)
				if choice == 1 then
					state = "telegraph_dash"
					actionEndTime = now + 0.7
					dashTarget = targetPos + Vector3.new(math.random(-8, 8), math.random(-2, 6), math.random(-8, 8))
					orb.Color = Color3.fromRGB(255, 140, 30)
					light.Color = Color3.fromRGB(255, 170, 60)
					light.Brightness = 4
					warningMarker(orb.Position, 0.7)
				elseif choice == 2 then
					state = "telegraph_spew"
					actionEndTime = now + 0.45
					orb.Color = Color3.fromRGB(255, 210, 60)
					light.Color = Color3.fromRGB(255, 220, 70)
					light.Brightness = 4
					warningMarker(orb.Position, 0.45)
				else
					state = "telegraph_freeze"
					actionEndTime = now + 0.8
					orb.Color = Color3.fromRGB(255, 255, 255)
					light.Color = Color3.fromRGB(255, 255, 255)
					light.Brightness = 6
					warningMarker(orb.Position, 0.8)
				end
			end

		elseif state == "telegraph_dash" then
			orb.CFrame = CFrame.new(orb.Position:Lerp(targetPos + Vector3.new(math.sin(now * 12 + index) * 4, 10, math.cos(now * 12 + index) * 4), math.clamp(dt * 2.8, 0, 1)), targetPos)
			orb.Color = (math.floor(now * 10) % 2 == 0) and Color3.fromRGB(255, 90, 20) or Color3.fromRGB(255, 190, 40)
			if now >= actionEndTime then
				state = "dash"
				dashTarget = targetPos + Vector3.new(math.random(-6, 6), math.random(-1, 4), math.random(-6, 6))
				dashSpeed = 150 + progress() * 80
			end

		elseif state == "dash" then
			local toTarget = dashTarget - orb.Position
			local step = toTarget.Unit * dashSpeed * dt
			if toTarget.Magnitude <= step.Magnitude then
				local hitPos = orb.Position
				explosionFlash(hitPos, 12, 260000)
				shockwave(hitPos, 6, 30, Color3.fromRGB(255, 150, 40), 0.35)
				applyLocalDamage(math.random(1, 4))
				applyKnockback(hrp.Position - hitPos, 80)
				if math.random() < 0.55 then
					mushroomCloud(hitPos)
				end
				resetToOrbit()
			else
				orb.CFrame = CFrame.new(orb.Position + step, hrp.Position)
				if (orb.Position - hrp.Position).Magnitude < 6 then
					local hitPos = orb.Position
					explosionFlash(hitPos, 12, 260000)
					shockwave(hitPos, 6, 30, Color3.fromRGB(255, 150, 40), 0.35)
					applyLocalDamage(math.random(1, 4))
					applyKnockback(hrp.Position - hitPos, 80)
					if math.random() < 0.55 then
						mushroomCloud(hitPos)
					end
					resetToOrbit()
				end
			end

		elseif state == "telegraph_spew" then
			orb.CFrame = CFrame.new(orb.Position:Lerp(targetPos + Vector3.new(math.sin(now * 9 + index) * 3, 11, math.cos(now * 9 + index) * 3), math.clamp(dt * 2.5, 0, 1)), targetPos)
			orb.Color = (math.floor(now * 12) % 2 == 0) and Color3.fromRGB(255, 240, 90) or Color3.fromRGB(255, 130, 40)
			if now >= actionEndTime then
				state = "spew"
				spewEndTime = now + 1.25 + progress() * 0.4
				spewLastShot = 0
			end

		elseif state == "spew" then
			orb.CFrame = CFrame.new(orb.Position:Lerp(targetPos + Vector3.new(math.sin(now * 7 + index) * 5, 12, math.cos(now * 7 + index) * 5), math.clamp(dt * 2.2, 0, 1)), targetPos)
			orb.Color = Color3.fromRGB(255, 80, 80)
			light.Color = Color3.fromRGB(255, 80, 80)
			light.Brightness = 4

			if now - spewLastShot > 0.06 then
				spewLastShot = now
				spewNeonSpheres(orb.Position, targetPos, math.random(2, 4))
			end

			if now >= spewEndTime then
				resetToOrbit()
			end

		elseif state == "telegraph_freeze" then
			orb.CFrame = CFrame.new(orb.Position:Lerp(targetPos + Vector3.new(math.sin(now * 10 + index) * 2, 13, math.cos(now * 10 + index) * 2), math.clamp(dt * 2, 0, 1)), targetPos)
			if math.floor(now * 14) % 2 == 0 then
				orb.Color = Color3.fromRGB(255, 255, 255)
				light.Color = Color3.fromRGB(255, 255, 255)
			else
				orb.Color = Color3.fromRGB(255, 240, 240)
				light.Color = Color3.fromRGB(255, 255, 255)
			end

			if now >= actionEndTime then
				state = "freeze"
				freezeEndTime = now + 0.55
				freezeLastSpark = 0
			end

		elseif state == "freeze" then
			orb.CFrame = CFrame.new(targetPos + Vector3.new(math.sin(now * 5 + index) * 1.5, 14, math.cos(now * 5 + index) * 1.5))
			orb.Color = Color3.fromRGB(255, 255, 255)
			light.Color = Color3.fromRGB(255, 255, 255)
			light.Brightness = 7

			if now - freezeLastSpark > 0.08 then
				freezeLastSpark = now
				local sparkOrigin = orb.Position + Vector3.new(math.random(-4, 4), math.random(-4, 4), math.random(-4, 4))
				local sparkTarget = sparkOrigin + Vector3.new(math.random(-20, 20), math.random(8, 24), math.random(-20, 20))
				spawnWhiteSquareParticle(sparkOrigin, sparkTarget, 100 + math.random(0, 50), math.random(1, 2), 1)
			end

			if now >= freezeEndTime then
				local hitPos = orb.Position
				warningMarker(hitPos, 0.2)
				task.delay(0.2, function()
					if not alive() then
						return
					end
					explosionFlash(hitPos, 20, 650000)
					shockwave(hitPos, 8, 42, Color3.fromRGB(255, 255, 255), 0.4)
					whiteExplosionBurst(hitPos)
					if math.random() < 0.7 then
						mushroomCloud(hitPos)
					end
					applyLocalDamage(math.random(2, 5))
					applyKnockback(hrp.Position - hitPos, 95)
				end)
				resetToOrbit()
			end
		end
	end)
end

