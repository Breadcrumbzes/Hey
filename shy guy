local function spawnApocalypseOrbs()
	if apocalypseBuilt or not hrp or not hrp.Parent then
		return
	end
	apocalypseBuilt = true

	for i = 1, 5 do
		task.spawn(function()
			if not hrp or not hrp.Parent then
				return
			end

			local orb = mkPart(
				Vector3.new(8, 8, 8),
				hrp.CFrame * CFrame.new(
					math.random(-120, 120),
					math.random(18, 40),
					math.random(-120, 120)
				),
				Color3.fromRGB(255, 30, 30),
				Enum.Material.Neon,
				true,
				false,
				0.05
			)
			orb.Shape = Enum.PartType.Ball

			local light = Instance.new("PointLight")
			light.Color = Color3.fromRGB(255, 35, 35)
			light.Range = 28
			light.Brightness = 2
			light.Parent = orb

			local ang = math.random() * math.pi * 2
			local radius = 90 + i * 8
			local state = "orbit"
			local stateTime = 0
			local nextAttack = 1.5 + math.random()
			local dashTarget = orb.Position
			local dashDuration = 1.15
			local spewTimer = 0
			local recoverTime = 0
			local freezePulse = 0

			local function setRed()
				orb.Color = Color3.fromRGB(255, 30, 30)
				light.Color = Color3.fromRGB(255, 40, 40)
				light.Brightness = 2
				orb.Transparency = 0.05
				orb.Size = Vector3.new(8, 8, 8)
			end

			local function setWhite()
				orb.Color = Color3.fromRGB(255, 255, 255)
				light.Color = Color3.fromRGB(255, 255, 255)
				light.Brightness = 5
				orb.Transparency = 0
				orb.Size = Vector3.new(10, 10, 10)
			end

			local function beginDash()
				state = "dash"
				stateTime = 0
				dashDuration = 0.8 + math.random() * 0.6
				dashTarget = hrp.Position + Vector3.new(
					math.random(-8, 8),
					math.random(-2, 6),
					math.random(-8, 8)
				)
			end

			local function beginSpew()
				state = "spew"
				stateTime = 0
				spewTimer = 0
			end

			local function beginFreeze()
				state = "freeze"
				stateTime = 0
				freezePulse = 0
			end

			local function returnToOrbit(delayBeforeNext: number)
				state = "recover"
				stateTime = 0
				recoverTime = delayBeforeNext
				setRed()
			end

			local conn: RBXScriptConnection?
			conn = RunService.Heartbeat:Connect(function(dt)
				if not alive() or not orb.Parent or not hrp.Parent then
					if conn then
						conn:Disconnect()
					end
					if orb.Parent then
						orb:Destroy()
					end
					return
				end

				stateTime += dt

				if state == "orbit" then
					ang += dt * (0.75 + i * 0.06)
					local orbitPos = hrp.Position + Vector3.new(
						math.cos(ang) * radius,
						math.sin(os.clock() * 1.8 + i) * 10 + 22,
						math.sin(ang) * radius
					)
					orb.CFrame = CFrame.new(orbitPos) * CFrame.Angles(0, os.clock() * 1.5, 0)

					local pulse = 0.85 + (math.sin(os.clock() * 6 + i) * 0.15)
					orb.Size = Vector3.new(8, 8, 8) * pulse
					light.Brightness = 1.5 + (math.sin(os.clock() * 8 + i) * 0.4)

					nextAttack -= dt
					if nextAttack <= 0 then
						local choice = math.random(1, 3)
						if choice == 1 then
							beginDash()
						elseif choice == 2 then
							beginSpew()
						else
							beginFreeze()
						end
					end

				elseif state == "dash" then
					local dir = dashTarget - orb.Position
					if dir.Magnitude < 0.001 then
						dir = Vector3.new(0, 0, -1)
					end
					dir = dir.Unit

					local speed = 150 + progress() * 70
					orb.CFrame = CFrame.new(orb.Position + dir * speed * dt, hrp.Position)
					orb.Color = Color3.fromRGB(255, 25, 25)
					light.Color = Color3.fromRGB(255, 80, 40)
					light.Brightness = 3

					if (orb.Position - hrp.Position).Magnitude < 7 or stateTime >= dashDuration then
						local hitPos = orb.Position
						shockwave(hitPos, 8, 34, Color3.fromRGB(255, 140, 50), 0.35)
						explosionFlash(hitPos, 12, 220000)
						applyLocalDamage(math.random(1, 4))
						applyKnockback(hrp.Position - hitPos, 85)
						if math.random() < 0.45 then
							mushroomCloud(hitPos)
						end
						returnToOrbit(1.0 + math.random() * 0.8)
					end

				elseif state == "spew" then
					orb.Color = Color3.fromRGB(255, 35, 35)
					light.Color = Color3.fromRGB(255, 80, 50)
					light.Brightness = 3.2

					spewTimer -= dt
					if spewTimer <= 0 then
						spewTimer = 0.06
						apocalypseOrbSpew(orb.Position)
					end

					orb.CFrame = CFrame.new(orb.Position, hrp.Position)

					if stateTime >= 1.1 then
						returnToOrbit(0.8 + math.random() * 0.6)
					end

				elseif state == "freeze" then
					freezePulse += dt
					setWhite()
					orb.CFrame = CFrame.new(orb.Position)

					if freezePulse > 0.12 then
						freezePulse = 0
						orb.Size = Vector3.new(10, 10, 10) + Vector3.new(math.random(0, 3), math.random(0, 3), math.random(0, 3))
					end

					if stateTime >= 0.9 then
						local hitPos = orb.Position
						explosionFlash(hitPos, 22, 800000)
						shockwave(hitPos, 10, 70, Color3.fromRGB(255, 255, 255), 0.55)
						whiteShardBurst(hitPos)
						mushroomCloud(hitPos)
						applyLocalDamage(math.random(2, 6))
						applyKnockback(hrp.Position - hitPos, 110)
						returnToOrbit(1.2 + math.random() * 0.9)
					end

				elseif state == "recover" then
					recoverTime -= dt
					orb.Color = Color3.fromRGB(255, 30, 30)
					light.Color = Color3.fromRGB(255, 40, 40)
					light.Brightness = 2

					local orbitPos = hrp.Position + Vector3.new(
						math.cos(ang) * radius,
						math.sin(os.clock() * 1.6 + i) * 9 + 20,
						math.sin(ang) * radius
					)
					orb.CFrame = CFrame.new(orbitPos)

					if recoverTime <= 0 then
						state = "orbit"
						stateTime = 0
						nextAttack = 1.3 + math.random() * 1.7
					end
				end
			end)
		end)
	end
end

