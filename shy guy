end

local function explosionRain()
	for i = 1, math.random(4, 10) do
		task.delay(math.random() * 0.9, function()
			if not alive() then
				return
			end
			local pos = hrp.Position + Vector3.new(math.random(-40, 40), math.random(12, 32), math.random(-40, 40))
			warningMarker(pos, 0.4)
			task.delay(0.4, function()
				if alive() then
					explosionFlash(pos, 10 + math.random(0, 7), 180000)
