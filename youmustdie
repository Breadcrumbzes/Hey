-- == CHAOTIC ROBLOX LOCALSCRIPT - LOCALPLAYER ONLY SURVIVAL HUNTER ==
-- Paste this as a LocalScript in StarterPlayer > StarterPlayerScripts
-- Targets ONLY LocalPlayer. No damage or effects on any other players.
-- Fully client-side damage (only your Humanoid is affected).
-- Multi-phase boss with ALL requested upgrades: 2.5x faster lunges but 1.5x shorter distance,
-- instant full stop on death, phase 3 constant screen shake, collidable 5x bigger red goop,
-- 10x bigger/more/farther black goo spew with knockback + sphere/cylinder chaos meshes,
-- overall way more chaos (more debris, higher jitter, faster everything).

local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- INSTANT DEATH STOP
local alive = true
humanoid.Died:Connect(function()
	alive = false
end)

-- ==================== CREATE THE BALL ====================
local ball = Instance.new("Part")
ball.Name = "ChaosHunterBall"
ball.Size = Vector3.new(25, 25, 25)
ball.Shape = Enum.PartType.Ball
ball.Material = Enum.Material.Neon
ball.Color = Color3.fromRGB(0, 0, 0)
ball.Transparency = 0
ball.Anchored = true
ball.CanCollide = false
ball.Parent = workspace

-- Decal on front
local decal = Instance.new("Decal")
decal.Face = Enum.NormalId.Front
decal.Texture = "rbxassetid://95222170052486"
decal.Parent = ball

-- Random spawn 100 studs away
local randomDir = Vector3.new(math.random(-1, 1), math.random(-1, 1), math.random(-1, 1)).Unit * 100
ball.Position = humanoidRootPart.Position + randomDir

-- ==================== CONSTANT HITBOX (2 damage every overlap) ====================
-- Only damages LocalPlayer, never others
ball.Touched:Connect(function(hit)
	if hit and hit:IsDescendantOf(character) then
		local hum = character:FindFirstChild("Humanoid")
		if hum then
			hum:TakeDamage(2)
		end
	end
end)

-- ==================== SOUND HELPER ====================
local function playSound(id, volume, playbackSpeed, parent)
	volume = volume or 1
	playbackSpeed = playbackSpeed or 1
	parent = parent or ball
	
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://" .. id
	sound.Volume = volume
	sound.PlaybackSpeed = playbackSpeed
	sound.Parent = parent
	sound:Play()
	
	sound.Ended:Connect(function()
		sound:Destroy()
	end)
	
	return sound
end

-- ==================== SCREEN SHAKE ====================
local function screenShake(duration, intensity)
	local conn
	local startTime = tick()
	conn = RunService.RenderStepped:Connect(function()
		if tick() - startTime > duration or not alive then
			conn:Disconnect()
			return
		end
		local offset = Vector3.new(
			math.random(-intensity, intensity) / 8,
			math.random(-intensity, intensity) / 8,
			0
		)
		workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame * CFrame.new(offset)
	end)
end

-- ==================== MAIN CHAOS LOOP ====================
task.spawn(function()
	-- PHASE 0: Initial spawn sound + screen shake
	local initSound = playSound(99762654932080, 5)
	screenShake(4, 8)
	initSound.Ended:Wait()

	if not alive then 
		if ball then ball:Destroy() end
		return 
	end

	-- Variables for phases (2.5x faster lunges, 1.5x shorter distance)
	local lungeCount = 0
	local lungeSpeed = 300 -- 120 * 2.5
	local pauseTime = 1.2
	local playbackSpeed = 1.0
	local phase = 1 -- 1 = normal, 2 = faster + black goo, 3 = red storm

	-- Red phase continuous red part storm (explosions everywhere)
	local redStormTask = nil

	while lungeCount < 30 and alive do
		lungeCount = lungeCount + 1

		-- Lungestart sound (gets faster in later phases)
		local lungestart = playSound(99762654932080, 5, playbackSpeed)

		-- Lunge sound
		playSound(94883125123730, 1)

		-- Face player
		local targetPos = humanoidRootPart.Position
		ball.CFrame = CFrame.lookAt(ball.Position, targetPos)

		-- LUNGE MOVEMENT + TRAIL CLONES (2.5x faster, 1.5x shorter)
		local moving = true
		local moveStart = tick()
		local lastTrail = tick()

		while moving and alive do
			task.wait(0.01)
			
			targetPos = humanoidRootPart.Position
			local dir = (targetPos - ball.Position).Unit
			
			-- Keep facing player (with chaotic red phase jitter)
			if phase == 3 then
				local jitter = CFrame.Angles(
					math.rad(math.random(-15, 15)),
					math.rad(math.random(-15, 15)),
					math.rad(math.random(-15, 15))
				)
				ball.CFrame = CFrame.lookAt(ball.Position, targetPos) * jitter
			else
				ball.CFrame = CFrame.lookAt(ball.Position, targetPos)
			end
			
			-- Move (2.5x faster)
			local step = lungeSpeed * 0.01
			ball.Position = ball.Position + dir * step
			
			-- Trail of transparent clones (more chaotic)
			if tick() - lastTrail > 0.03 then
				lastTrail = tick()
				local clone = ball:Clone()
				clone.Transparency = 0.6
				clone.Anchored = true
				clone.CanCollide = false
				clone.Parent = workspace
				
				TweenService:Create(clone, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {Transparency = 1}):Play()
				task.delay(0.8, function() if clone then clone:Destroy() end end)
			end
			
			-- Stop when close (1.5x shorter = 8 studs) or timeout (shorter = 4s)
			if (ball.Position - targetPos).Magnitude < 8 or (tick() - moveStart > 4) then
				moving = false
			end
		end

		if not alive then break end

		-- PHASE 3 SCREEN SHAKE on every lunge
		if phase == 3 then
			screenShake(0.7, 12)
		end

		-- Freeze & rotate back to player
		task.wait(pauseTime)
		ball.CFrame = CFrame.lookAt(ball.Position, humanoidRootPart.Position)

		-- ==================== PHASE TRANSITIONS ====================
		if lungeCount == 10 then
			-- Transition to phase 2
			phase = 2
			screenShake(5, 18)
			playSound(96184137289030, 1)
			local transition2 = playSound(106068332784548, 1)
			transition2.Ended:Wait()
			
			-- Start speeding up (already 2.5x base)
			playbackSpeed = 1.3
			lungeSpeed = 425 -- 170 * 2.5
			pauseTime = 0.7
			
		elseif phase == 2 and (lungeCount - 10) % 3 == 0 then
			-- Every 3 lunges in phase 2: point up and SPEW MASSIVE BLACK GOO (10x bigger, way more, farther, knockback + sphere/cylinder chaos)
			ball.CFrame = CFrame.lookAt(ball.Position, ball.Position + Vector3.new(0, 100, 0)) -- face up
			
			for i = 1, 40 do -- 3x+ more spewing
				local goo = Instance.new("Part")
				
				-- Cool sphere / cylinder mesh variety
				if math.random() < 0.65 then
					goo.Shape = Enum.PartType.Ball
					goo.Size = Vector3.new(30, 30, 30) -- 10x bigger
				else
					goo.Shape = Enum.PartType.Cylinder
					goo.Size = Vector3.new(10, 45, 10) -- long chaotic cylinders
				end
				
				goo.Material = Enum.Material.Neon
				goo.Color = Color3.new(0, 0, 0)
				goo.Position = ball.Position + Vector3.new(math.random(-12, 12), 5, math.random(-12, 12))
				
				-- Spews MUCH farther into the air + chaotic velocity
				goo.Velocity = Vector3.new(
					math.random(-140, 140),
					math.random(200, 350),
					math.random(-140, 140)
				)
				goo.CanCollide = false
				goo.Anchored = false
				goo.Parent = workspace
				
				-- Black goo damages + knockback + dissolve on touch (only LocalPlayer)
				goo.Touched:Connect(function(hit)
					if hit and hit:IsDescendantOf(character) and alive then
						humanoid:TakeDamage(28)
						-- Knockback chaos
						if humanoidRootPart then
							local knockDir = (humanoidRootPart.Position - goo.Position).Unit * 110 + Vector3.new(0, 45, 0)
							humanoidRootPart.Velocity = humanoidRootPart.Velocity + knockDir
						end
					end
				end)
				
				playSound(109182232826928, 1.2, 1, goo)
				task.delay(5, function() if goo then goo:Destroy() end end)
				task.wait(0.012) -- faster spew
			end
			task.wait(1.2)
			
		elseif lungeCount == 20 then
			-- Transition to phase 3 - RED MODE + PHASE 3 SCREEN SHAKE ALREADY ACTIVE
			phase = 3
			ball.Color = Color3.fromRGB(255, 0, 0)
			playSound(137944174609015, 5)
			
			-- 2x speed on top of the 2.5x (insane)
			lungeSpeed = lungeSpeed * 2
			playbackSpeed = 1.9
			pauseTime = 0.35
			
			-- Start red part storm (5x bigger, collidable, more chaos)
			redStormTask = task.spawn(function()
				while phase == 3 and lungeCount < 30 and alive do
					for i = 1, 15 do -- more red goop
						local red = Instance.new("Part")
						red.Size = Vector3.new(10, 10, 10) -- 5x bigger
						red.Shape = Enum.PartType.Ball
						red.Material = Enum.Material.Neon
						red.Color = Color3.fromRGB(255, 50, 0)
						red.Position = ball.Position + Vector3.new(math.random(-20, 20), math.random(-15, 30), math.random(-20, 20))
						red.Velocity = Vector3.new(math.random(-220, 220), math.random(-60, 150), math.random(-220, 220))
						red.CanCollide = true -- now collidable
						red.Anchored = false
						red.Parent = workspace
						
						red.Touched:Connect(function(hit)
							if hit and hit:IsDescendantOf(character) and alive then
								humanoid:TakeDamage(14)
								playSound(140615626179933, 1)
							end
						end)
						
						task.delay(2.8, function() if red then red:Destroy() end end)
					end
					task.wait(0.055) -- even faster storm
				end
			end)
			
		elseif phase == 3 and lungeCount > 20 then
			-- Phase 3 spew exchanged for glowing exploding orbs (even more chaos)
			if (lungeCount - 20) % 3 == 0 then
				for i = 1, 25 do -- more orbs
					local orb = Instance.new("Part")
					orb.Size = Vector3.new(5, 5, 5)
					orb.Shape = Enum.PartType.Ball
					orb.Material = Enum.Material.Neon
					orb.Color = Color3.fromRGB(255, 255, 80)
					orb.Transparency = 0.05
					orb.Position = ball.Position
					orb.CanCollide = true
					orb.Anchored = false
					orb.Velocity = (humanoidRootPart.Position - orb.Position).Unit * 180 + Vector3.new(math.random(-45, 45), 35, math.random(-45, 45))
					orb.Parent = workspace
					
					orb.Touched:Connect(function(hit)
						if hit and hit:IsDescendantOf(character) and alive then
							humanoid:TakeDamage(17)
							playSound(140615626179933, 1.3)
							orb:Destroy()
						end
					end)
					
					task.wait(0.028)
				end
				task.wait(0.8)
			end
		end

		-- At exactly 30 lunges: final dramatic shake + BURST (extra chaos)
		if lungeCount == 30 and alive then
			screenShake(5, 18)
			local shakeStart = tick()
			while tick() - shakeStart < 5 and alive do
				local intenseRot = math.sin(tick() * 55) * 35
				ball.Orientation = ball.Orientation + Vector3.new(intenseRot, intenseRot * 1.2, intenseRot * 0.5)
				task.wait(0.008)
			end
			
			-- BURST EXPLOSION
			local burstTween = TweenService:Create(ball, TweenInfo.new(1.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = ball.Size * 10,
				Transparency = 1
			})
			burstTween:Play()
			
			-- MASSIVE explosion of black goo + red orbs + red goo (more debris)
			for i = 1, 110 do
				local debris = Instance.new("Part")
				debris.Size = Vector3.new(6, 6, 6)
				debris.Shape = Enum.PartType.Ball
				debris.Material = Enum.Material.Neon
				if i % 3 == 0 then
					debris.Color = Color3.new(0, 0, 0)
				else
					debris.Color = Color3.fromRGB(255, 30, 0)
				end
				debris.Position = ball.Position + Vector3.new(math.random(-40, 40), math.random(-25, 55), math.random(-40, 40))
				debris.Velocity = Vector3.new(math.random(-380, 380), math.random(120, 320), math.random(-380, 380))
				debris.CanCollide = true
				debris.Anchored = false
				debris.Parent = workspace
				
				debris.Touched:Connect(function(hit)
					if hit and hit:IsDescendantOf(character) and alive then
						humanoid:TakeDamage(38)
					end
				end)
				
				if i % 3 == 0 then
					playSound(140615626179933, 1.8)
				end
				
				task.delay(4.5, function() if debris then debris:Destroy() end end)
				task.wait(0.006)
			end
			
			task.delay(20, function()
				if ball then ball:Destroy() end
			end)
			
			break
		end
	end
	
	-- Cleanup everything instantly if dead or ended
	if redStormTask then
		task.cancel(redStormTask)
	end
	if ball and not alive then
		ball:Destroy()
	end
end)

