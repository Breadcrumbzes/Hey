local function createExplosion(pos, radius, damage, knockStrength, soundId, particleColor, isGiant)
	if not alive then
		return
	end

	playSound(soundId or 140653132496955, isGiant and 8 or 4, 1, workspace, false)

	local sphere = trackInstance(Instance.new("Part"))
	sphere.Name = "ChaosExplosionSphere"
	sphere.Shape = Enum.PartType.Ball
	sphere.Size = Vector3.new(1, 1, 1)
	sphere.CFrame = CFrame.new(pos)
	sphere.Material = Enum.Material.Neon
	sphere.Color = particleColor or Color3.fromRGB(255, 100, 0)
	sphere.Transparency = 0.3
	sphere.Anchored = true
	sphere.CanCollide = false
	sphere.CanTouch = false
	sphere.CanQuery = false
	sphere.Parent = workspace
    radius = radius * (1.5 + math.random())
	local sphereTween = TweenService:Create(
		sphere,
		TweenInfo.new(isGiant and 1.2 or 0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Size = Vector3.new(radius, radius , radius ), Transparency = 1 }
	)
	sphereTween:Play()
	sphereTween.Completed:Connect(function()
		pcall(function()
			sphere:Destroy()
		end)
	end)

	local particlePart = trackInstance(Instance.new("Part"))
	particlePart.Name = "ChaosExplosionParticles"
	particlePart.Size = Vector3.new(0.1, 0.1, 0.1)
	particlePart.Transparency = 1
	particlePart.Anchored = true
	particlePart.CanCollide = false
	particlePart.Position = pos
	particlePart.Parent = workspace

	local pe = Instance.new("ParticleEmitter")
	pe.Texture = "rbxassetid://954619039"
	pe.Color = ColorSequence.new(particleColor or Color3.fromRGB(255, 120, 0))
	pe.LightEmission = 1
	pe.Size = NumberSequence.new(isGiant and 4 or 2.5)
	pe.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(1, 1),
	})
	pe.Lifetime = NumberRange.new(2.5, 3)
	pe.Rate = 0
	pe.Speed = NumberRange.new(isGiant and 85 or 45)
	pe.SpreadAngle = Vector2.new(360, 360)
	pe.Parent = particlePart
	pe:Emit(isGiant and 120 or 55)

	task.delay(3, function()
		pcall(function()
			particlePart:Destroy()
		end)
	end)

	local dist = (humanoidRootPart.Position - pos).Magnitude
	if dist < radius then
		humanoid:TakeDamage(damage)
		local dir = safeUnit(humanoidRootPart.Position - pos, Vector3.new(0, 1, 0))
		humanoidRootPart.AssemblyLinearVelocity = dir * knockStrength + Vector3.new(0, 60, 0)
	end
end

--========================
-- Projectile helper
--========================
local function fireProjectile(origin, direction, speed, lifetime, size, color3, imageColor3, impactRadius, damage, knockStrength, soundId, giant, sourcePart)
	direction = safeUnit(direction, Vector3.new(0, 0, -1))

	local projPart = trackInstance(Instance.new("Part"))
	projPart.Name = "ChaosProjectile"
	projPart.Size = Vector3.new(size, size, size)
	projPart.Anchored = true
	projPart.CanCollide = false
	projPart.CanTouch = false
	projPart.CanQuery = false
	projPart.Material = Enum.Material.Neon
	projPart.Color = color3
	projPart.Transparency = 0.15
	projPart.CFrame = CFrame.new(origin, origin + direction)
	projPart.Parent = workspace

	local bb = Instance.new("BillboardGui")
	bb.Adornee = projPart
	bb.AlwaysOnTop = false
	bb.LightInfluence = 0
	bb.Size = UDim2.fromScale(giant and 100 or 50, giant and 100 or 50)
	bb.StudsOffsetWorldSpace = Vector3.zero
	bb.MaxDistance = 100000
	bb.Parent = projPart

	local img = Instance.new("ImageLabel")
	img.Size = UDim2.fromScale(1, 1)
	img.BackgroundTransparency = 1
	img.Image = "rbxassetid://954619039"
	img.ImageColor3 = imageColor3 or color3
	img.ScaleType = Enum.ScaleType.Fit
	img.Parent = bb

	playSound(soundId or 140653132496955, giant and 4 or 2.5, 1, workspace, false)

	local born = os.clock()
	local prevPos = origin

	task.spawn(function()
		local rayParams = RaycastParams.new()
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		rayParams.FilterDescendantsInstances = sourcePart and { projPart, sourcePart } or { projPart }
		rayParams.IgnoreWater = true

		while alive and projPart.Parent do
			local dt = RunService.Heartbeat:Wait()
			if not alive then
				break
			end

			local newPos = prevPos + direction * speed * dt
			local hit = workspace:Raycast(prevPos, newPos - prevPos, rayParams)

			prevPos = newPos
			projPart.CFrame = CFrame.new(newPos, newPos + direction)

			if hit then
				createExplosion(
					hit.Position,
					impactRadius,
					damage,
					knockStrength,
					soundId or 140653132496955,
					color3,
					giant
				)
				break
			end

			if (newPos - humanoidRootPart.Position).Magnitude <= impactRadius then
				createExplosion(
					newPos,
					impactRadius,
					damage,
					knockStrength,
					soundId or 140653132496955,
					color3,
					giant
				)
				break
			end

			if os.clock() - born >= lifetime then
				break
			end
		end

		pcall(function()
			projPart:Destroy()
		end)
	end)
end

