					end

					if alive and burstPart.Parent then
						createExplosion(burstPart.Position, 12, 30, 140, 140653132496955, Color3.fromRGB(255, 60, 60), false)
					end

					pcall(function()
						burstPart:Destroy()
					end)
				end)
			end
		end

		-- Phase 5 meteor spam
		if phase == 5 and rng:NextNumber() < 0.12 then
			local meteorPos = humanoidRootPart.Position + Vector3.new(randf(-80, 80), 140, randf(-80, 80))
			local meteorColor = Color3.fromRGB(255, 255, 80)

			fireProjectile(
				meteorPos,
				Vector3.new(randf(-0.15, 0.15), -1, randf(-0.15, 0.15)),
				55,
				6,
				6,
				meteorColor,
				meteorColor,
				22,
				45,
				220,
				140653132496955,
				true,
				hunter
			)
		end

		task.wait(0.01)
	end

	-- Final sequence
	if alive then
		screenShake(4, 35)
		createExplosion(hunter.Position, 35, 0, 0, 140653132496955, Color3.fromRGB(255, 255, 100), true)

		for i = 1, 6 do
			task.delay(i * 0.12, function()
				if not alive then
					return
				end

				local ring = trackInstance(Instance.new("Part"))
				ring.Name = "FinalRing"
				ring.Shape = Enum.PartType.Ball
				ring.Size = Vector3.new(5, 5, 5)
				ring.CFrame = CFrame.new(hunter.Position)
				ring.Material = Enum.Material.Neon
				ring.Color = Color3.fromRGB(255, 255, 100)
				ring.Transparency = 0.2
				ring.Anchored = true
				ring.CanCollide = false
				ring.CanTouch = false
				ring.CanQuery = false
				ring.Parent = workspace

				TweenService:Create(
					ring,
					TweenInfo.new(1.1, Enum.EasingStyle.Quad),
					{ Size = Vector3.new(60, 60, 60), Transparency = 1 }
				):Play()

				task.delay(1.2, function()
					pcall(function()
						ring:Destroy()
					end)
				end)
			end)
		end

		for i = 1, 35 do
			task.delay(i * 0.02, function()
				if not alive then
					return
				end

				local dir = safeUnit(Vector3.new(randf(-1, 1), randf(0, 1), randf(-1, 1)), Vector3.new(0, 1, 0))
				local proj = trackInstance(Instance.new("Part"))
				proj.Name = "FinalBurstProjectile"
				proj.Size = Vector3.new(2.5, 2.5, 2.5)
				proj.Material = Enum.Material.Neon
				proj.Color = Color3.fromRGB(255, 255, 100)
				proj.CFrame = CFrame.new(hunter.Position, hunter.Position + dir)
				proj.Anchored = true
				proj.CanCollide = false
				proj.CanTouch = false
				proj.CanQuery = false
				proj.Parent = workspace

				task.spawn(function()
					local start = os.clock()
					local pos = hunter.Position
					while alive and proj.Parent and (os.clock() - start) < 2 do
						local dt = RunService.Heartbeat:Wait()
						pos = pos + dir * 180 * dt
						proj.CFrame = CFrame.new(pos, pos + dir)

						if (pos - humanoidRootPart.Position).Magnitude <= 10 then
							createExplosion(pos, 10, 0, 0, 140653132496955, Color3.fromRGB(255, 255, 100), false)
							break
						end
					end

					pcall(function()
						proj:Destroy()
					end)
				end)
			end)
		end

		task.wait(1.6)
	end

	cleanupAll()
	print("✅ CHAOS HUNTER FINISHED / CLEARED")
end)

