local startTime = os.clock()
local phase = 1

local currentSpeed = 20
local musicSound = playSound(122940626704593, 4, 1, workspace, true)

local lastProjectileTime = 0
local lastRedBurstTime = 0
local lastShotgunTime = 0
local lastFallingRainTime = 0
