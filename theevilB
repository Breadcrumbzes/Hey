--========================
-- Camera shake
--========================
local shakeConn
local function screenShake(duration, intensity)
	if not alive then
		return
	end

	if shakeConn then
		shakeConn:Disconnect()
		shakeConn = nil
	end

	local startT = os.clock()
	shakeConn = trackConnection(RunService.RenderStepped:Connect(function()
		if not alive then
			if humanoid then
				humanoid.CameraOffset = Vector3.zero
			end
			if shakeConn then
				shakeConn:Disconnect()
				shakeConn = nil
			end
			return
		end

		if os.clock() - startT >= duration then
			humanoid.CameraOffset = Vector3.zero
			if shakeConn then
				shakeConn:Disconnect()
				shakeConn = nil
			end
			return
		end

		humanoid.CameraOffset = Vector3.new(
			randf(-intensity, intensity) / 10,
			randf(-intensity, intensity) / 10,
			0
		)
	end))
end

