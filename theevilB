--========================
-- Cleanup tracking
--========================
local trackedInstances = {}
local trackedConnections = {}
local activeSounds = {}

local function trackInstance(inst)
	table.insert(trackedInstances, inst)
	return inst
end

local function trackConnection(conn)
	table.insert(trackedConnections, conn)
	return conn
end

local function removeSoundFromActive(sound)
	for i = #activeSounds, 1, -1 do
		if activeSounds[i] == sound then
			table.remove(activeSounds, i)
			return
		end
	end
end

local function stopSound(sound)
	if not sound then
		return
	end
	removeSoundFromActive(sound)
	pcall(function()
		sound:Stop()
		sound:Destroy()
	end)
end

local function stopAllSounds()
	for i = #activeSounds, 1, -1 do
		local s = activeSounds[i]
		pcall(function()
			if s then
				s:Stop()
				s:Destroy()
			end
		end)
		table.remove(activeSounds, i)
	end
end

local function cleanupAll()
	if cleanedUp then
		return
	end
	cleanedUp = true
	alive = false

	pcall(function()
		humanoid.CameraOffset = Vector3.zero
	end)

	for i = #trackedConnections, 1, -1 do
		local conn = trackedConnections[i]
		pcall(function()
			conn:Disconnect()
		end)
		table.remove(trackedConnections, i)
	end

	stopAllSounds()

	for i = #trackedInstances, 1, -1 do
		local inst = trackedInstances[i]
		pcall(function()
			if inst and inst.Parent then
				inst:Destroy()
			end
		end)
		table.remove(trackedInstances, i)
	end
end

--========================
-- Helpers
--========================
local function randf(a, b)
	return rng:NextNumber(a, b)
end

local function randi(a, b)
	return rng:NextInteger(a, b)
end

local function safeUnit(v, fallback)
	fallback = fallback or Vector3.new(0, 0, -1)
	if typeof(v) ~= "Vector3" then
		return fallback
	end
	local m = v.Magnitude
	if m < 1e-6 then
		return fallback
	end
	return v / m
end

local function randomUnit2D()
	local angle = randf(0, math.pi * 2)
	return Vector3.new(math.cos(angle), 0, math.sin(angle))
end

local function makeSpreadDirection(baseDir, maxAngleDeg)
	baseDir = safeUnit(baseDir, Vector3.new(0, 0, -1))
	local yaw = math.rad(randf(-maxAngleDeg, maxAngleDeg))
	local pitch = math.rad(randf(-maxAngleDeg, maxAngleDeg))
	local look = CFrame.lookAt(Vector3.zero, baseDir)
	local spreadCf = look * CFrame.Angles(pitch, yaw, 0)
	return safeUnit(spreadCf.LookVector, baseDir)
end

local function playSound(id, volume, speed, parent, looped)
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://" .. tostring(id)
	sound.Volume = volume or 3
	sound.PlaybackSpeed = speed or 1
	sound.Looped = looped or false
	sound.Parent = parent or workspace
	sound:Play()

	table.insert(activeSounds, sound)

	sound.Ended:Connect(function()
		removeSoundFromActive(sound)
		pcall(function()
			sound:Destroy()
		end)
	end)

	return sound
end

