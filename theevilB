end

local function createOrbiters(distance, color, biggeroffset, amount)
	if orbitersSpawned then
		return
	end
	orbitersSpawned = true
	orbitersActive = true

	for i = 1, amount do
		local orb = trackInstance(Instance.new("Part"))
		orb.Name = "ChaosOrbiter"
		orb.Size = Vector3.new(2.5, 2.5, 2.5)
		orb.Material = Enum.Material.Neon
		orb.Color = Color3.fromRGB(180, 80, 255)
		orb.Transparency = 0.3
		orb.Anchored = true
		orb.CanCollide = false
		orb.Parent = workspace

		local orbBillboard = Instance.new("BillboardGui")
		orbBillboard.Adornee = orb
		orbBillboard.AlwaysOnTop = false
		orbBillboard.LightInfluence = 0
		orbBillboard.Size = UDim2.fromOffset(20, 20)
		orbBillboard.StudsOffsetWorldSpace = Vector3.zero
		orbBillboard.MaxDistance = 100000
		orbBillboard.Parent = orb

		local orbImg = Instance.new("ImageLabel")
		orbImg.Size = UDim2.fromScale(1, 1)
		orbImg.BackgroundTransparency = 1
		orbImg.Image = "rbxassetid://954619039"
		orbImg.ImageColor3 = color
		orbImg.ScaleType = Enum.ScaleType.Fit
		orbImg.Parent = orbBillboard

		table.insert(orbiters, {
			part = orb,
			angle = (i - 1) * (math.pi * 2 / 4),
			radius = distance,
			height = 8 + i * 2,
			speed = 1.6 + i * 0.2,
		})
	end

	-- 🔵 MOVEMENT LOOP
	task.spawn(function()
		while alive and orbitersActive do
			if not humanoidRootPart then
				task.wait()
				continue
			end

			for _, orbData in ipairs(orbiters) do
				if orbData.part and orbData.part.Parent then
					orbData.angle += orbData.speed * 0.03

					local offset = Vector3.new(
						math.cos(orbData.angle) * orbData.radius,
						orbData.height,
						math.sin(orbData.angle) * orbData.radius
					)

					orbData.part.Position = humanoidRootPart.Position +biggeroffset + offset
				end
			end

			task.wait()
		end
	end)

	-- 🔴 SHOOTING LOOP
	task.spawn(function()
		while alive and orbitersActive and phase >= 4 do
			for _, orbData in ipairs(orbiters) do
				if not (orbData.part and orbData.part.Parent and humanoidRootPart) then
					continue
				end

				task.wait(randf(1.2, 3))

				if not alive then
					break
				end

				local orbPos = orbData.part.Position
				local shootDir = (humanoidRootPart.Position - orbPos).Unit

				fireProjectile(
					orbPos + shootDir * 4,
					shootDir,
					220,
					4,
					1.5,
					Color3.fromRGB(180, 80, 255),
					Color3.fromRGB(200, 100, 255),
					9,
					22,
					110,
					140653132496955,
					false,
					orbData.part
				)
			end
		end
	end)
end

